package pages

import (
	"fmt"
	"accounting-agent/internal/app"
	"accounting-agent/web/templates/layouts"
)

// VendorsList renders the vendor master list page.
templ VendorsList(d layouts.AppLayoutData, result *app.VendorsResult) {
	@layouts.AppLayout(d) {
		<div class="space-y-5">
			<!-- Header -->
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-bold text-slate-900">Vendors</h1>
					<p class="text-sm text-slate-500 mt-0.5">
						{ fmt.Sprintf("%d active vendor(s)", len(result.Vendors)) }
					</p>
				</div>
				<a
					href="/purchases/vendors/new"
					class="px-4 py-2 text-sm font-medium bg-slate-800 hover:bg-slate-700 text-white rounded-lg transition-colors"
				>
					+ New Vendor
				</a>
			</div>
			<!-- Table -->
			<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
				if len(result.Vendors) == 0 {
					<div class="empty-state">
						<div class="empty-state-icon">🏢</div>
						<div class="empty-state-title">No vendors yet</div>
						<div class="empty-state-text">
							<a href="/purchases/vendors/new" class="text-slate-700 underline hover:text-slate-900">Create your first vendor</a>
						</div>
					</div>
				} else {
					<table class="data-table">
						<thead>
							<tr>
								<th>Code</th>
								<th>Name</th>
								<th class="hidden md:table-cell">Contact</th>
								<th class="hidden lg:table-cell">Email</th>
								<th class="hidden sm:table-cell">Payment Terms</th>
								<th class="hidden sm:table-cell">AP Account</th>
							</tr>
						</thead>
						<tbody>
							for _, v := range result.Vendors {
								<tr>
									<td class="font-mono font-medium">{ v.Code }</td>
									<td class="font-medium">{ v.Name }</td>
									<td class="text-slate-500 hidden md:table-cell">
										if v.ContactPerson != nil {
											{ *v.ContactPerson }
										} else {
											<span class="text-slate-300">—</span>
										}
									</td>
									<td class="text-slate-500 hidden lg:table-cell">
										if v.Email != nil {
											{ *v.Email }
										} else {
											<span class="text-slate-300">—</span>
										}
									</td>
									<td class="text-right text-slate-700 hidden sm:table-cell">
										{ fmt.Sprintf("Net %d days", v.PaymentTermsDays) }
									</td>
									<td class="num font-mono text-slate-500 hidden sm:table-cell">
										{ v.APAccountCode }
									</td>
								</tr>
							}
						</tbody>
					</table>
				}
			</div>
		</div>
	}
}

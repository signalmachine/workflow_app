{{define "web_head"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{if .Title}}{{.Title}}{{else}}workflow_app{{end}}</title>
  <style>{{template "web_styles" .}}</style>
</head>
{{end}}

{{define "web_shell_start"}}
{{template "web_head" .}}
<body>
  <div class="shell-frame">
    <header class="shell-header">
      <div class="shell-header-row">
        <div class="brand-block">
          <div class="brand-mark">Workflow shell</div>
          <h1>workflow_app</h1>
          <p>AI-agent-first workflow review on one shared backend truth.</p>
        </div>

        {{if .Session}}
        <div class="session-card">
          <div class="eyebrow">Operator session</div>
          <div class="session-title"><strong>{{.Session.UserEmail}}</strong> in <strong>{{.Session.OrgSlug}}</strong></div>
          <div class="session-meta">Primary workflow destinations stay global while settings and admin remain secondary utility surfaces.</div>
        </div>
        {{end}}
      </div>

      {{if .Session}}
      <div class="shell-nav">
        <div class="nav-band">
          <div class="nav-band-label">Workflow destinations</div>
          <div class="nav-bubbles">
            <a href="/app" class="{{navClass .ActivePath "/app"}}">Home</a>
            <a href="/app/submit-inbound-request" class="{{navClass .ActivePath "/app/submit-inbound-request"}}">Intake</a>
            <a href="/app/operations-feed" class="{{navClass .ActivePath "/app/operations-feed"}}">Operations</a>
            <a href="/app/agent-chat" class="{{navClass .ActivePath "/app/agent-chat"}}">Agent chat</a>
            <a href="/app/review/inbound-requests" class="{{navClass .ActivePath "/app/review/inbound-requests"}}">Inbound requests</a>
            <a href="/app/review/proposals" class="{{navClass .ActivePath "/app/review/proposals"}}">Proposals</a>
            <a href="/app/review/approvals" class="{{navClass .ActivePath "/app/review/approvals"}}">Approvals</a>
          </div>
        </div>

        <div class="nav-band nav-band-secondary">
          <div class="nav-band-label">Review routes</div>
          <div class="nav-bubbles">
            <a href="/app/review/documents" class="{{navClass .ActivePath "/app/review/documents"}}">Documents</a>
            <a href="/app/review/accounting" class="{{navClass .ActivePath "/app/review/accounting"}}">Accounting</a>
            <a href="/app/review/inventory" class="{{navClass .ActivePath "/app/review/inventory"}}">Inventory</a>
            <a href="/app/review/work-orders" class="{{navClass .ActivePath "/app/review/work-orders"}}">Work orders</a>
            <a href="/app/review/audit" class="{{navClass .ActivePath "/app/review/audit"}}">Audit</a>
          </div>
        </div>

        <details class="utility-menu">
          <summary>Session menu</summary>
          <div class="utility-menu-panel">
            <div class="meta">Settings will stay user-scoped here as the browser layer grows.</div>
            {{if eq .Session.RoleCode "admin"}}
            <div class="meta">Admin surfaces should enter through this utility path rather than the primary workflow bar.</div>
            {{else}}
            <div class="meta">Admin surfaces stay out of the primary workflow bar unless the current actor has the required role.</div>
            {{end}}
            <form method="post" action="/app/logout">
              <button type="submit" class="secondary">Sign out</button>
            </form>
          </div>
        </details>
      </div>
      {{end}}
    </header>

    <main class="shell-main">
      <div class="page-stack">
        {{template "web_flash" .}}
{{end}}

{{define "web_shell_end"}}
      </div>
    </main>
  </div>
</body>
</html>
{{end}}

{{define "web_public_start"}}
{{template "web_head" .}}
<body class="login-shell">
  <div class="public-shell">
    {{template "web_flash" .}}
{{end}}

{{define "web_public_end"}}
  </div>
</body>
</html>
{{end}}

{{define "web_flash"}}
{{if .Notice}}
<div class="flash-stack">
  <div class="flash notice">{{.Notice}}</div>
</div>
{{end}}
{{if .Error}}
<div class="flash-stack">
  <div class="flash error">{{.Error}}</div>
</div>
{{end}}
{{end}}

{{define "web_page_header"}}
<section class="page-header">
  {{if index . "eyebrow"}}<div class="eyebrow">{{index . "eyebrow"}}</div>{{end}}
  <h1>{{index . "title"}}</h1>
  {{if index . "body"}}<p>{{index . "body"}}</p>{{end}}
</section>
{{end}}

{{define "web_summary_card"}}
<section class="summary-card">
  {{if index . "label"}}<div class="eyebrow">{{index . "label"}}</div>{{end}}
  {{if index . "value"}}<div class="count">{{index . "value"}}</div>{{end}}
  {{if index . "body"}}<div class="meta">{{index . "body"}}</div>{{end}}
  {{if and (index . "action_href") (index . "action_label")}}
  <div class="meta"><a href="{{index . "action_href"}}">{{index . "action_label"}}</a></div>
  {{end}}
</section>
{{end}}

{{define "web_empty_state"}}
<div class="empty-state">
  <h3>{{index . "title"}}</h3>
  <p>{{index . "body"}}</p>
</div>
{{end}}

{{define "web_detail_block"}}
<div class="detail-block">
  <div class="eyebrow">{{index . "label"}}</div>
  <div>{{index . "value"}}</div>
  {{if index . "body"}}<div class="meta">{{index . "body"}}</div>{{end}}
</div>
{{end}}

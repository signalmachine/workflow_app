      <table>
        <thead>
          <tr>
            <th>Account</th>
            <th>Control type</th>
            <th>Net</th>
            <th>As of</th>
          </tr>
        </thead>
        <tbody>
          {{range .Accounting.ControlBalances}}
          <tr>
            <td><a href="{{controlAccountHref .AccountID}}">{{.AccountCode}}</a><div class="meta">{{.AccountName}}</div></td>
            <td><a href="{{accountingReviewHref "" "" "" "" "" "" "" .ControlType "" ""}}">{{.ControlType}}</a></td>
            <td>{{.NetMinor}}</td>
            <td>{{if .LastEffectiveOn.Valid}}{{formatTime .LastEffectiveOn.Time}}{{else}}-{{end}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{else}}
    {{template "web_empty_state" (dict "title" "No control balances match the current filters." "body" "Control-account review remains available once journal data is present." )}}
    {{end}}
  </section>

  <section class="table-card">
    <div class="section-head">
      <div>
        <div class="eyebrow">Tax review</div>
        <h2>Tax summaries</h2>
      </div>
    </div>
    {{if .Accounting.TaxSummaries}}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Tax</th>
            <th>Entries</th>
            <th>Net</th>
            <th>Continuity</th>
          </tr>
        </thead>
        <tbody>
          {{range .Accounting.TaxSummaries}}
          <tr>
            <td><a href="{{taxSummaryHref .TaxCode}}">{{.TaxCode}}</a><div class="meta">{{.TaxName}}</div></td>
            <td>{{.EntryCount}} entries / {{.DocumentCount}} documents</td>
            <td>{{.NetMinor}}</td>
            <td class="inline-links">
              <a href="{{accountingReviewHref "" "" "" "" "" .TaxType .TaxCode "" "" "tax-summaries"}}">Filtered tax view</a>
              {{if .ReceivableAccountID.Valid}}<a href="{{controlAccountHref .ReceivableAccountID.String}}">{{.ReceivableAccountCode.String}}</a>{{end}}
              {{if .PayableAccountID.Valid}}<a href="{{controlAccountHref .PayableAccountID.String}}">{{.PayableAccountCode.String}}</a>{{end}}
            </td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{else}}
    {{template "web_empty_state" (dict "title" "No tax summaries match the current filters." "body" "Tax summary review will appear here once relevant posting activity exists." )}}
    {{end}}
  </section>
</div>

{{template "web_shell_end" .}}
{{end}}

{{define "web_inventory"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Inventory review"
  "body" "Keep stock balances, movement history, and reconciliation in one shared surface with exact continuity into items, locations, documents, and accounting."

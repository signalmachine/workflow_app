{{define "web_operations_landing"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Operations"
  "title" "Queue-driven operations"
  "body" "Use this page as a simple route directory for queue-moving work."
)}}

<section class="plain-section">
  <div class="eyebrow">Current workflow links</div>
  <div class="metric-list">
    <a href="/app/review/inbound-requests?status=queued" class="metric-link"><span class="metric-label">Queued requests</span><span class="metric-value">{{.OperationsLanding.QueuedRequestCount}}</span></a>
    <a href="/app/review/approvals?status=pending" class="metric-link"><span class="metric-label">Pending approvals</span><span class="metric-value">{{.OperationsLanding.PendingApprovalCount}}</span></a>
    <a href="/app/review/proposals" class="metric-link"><span class="metric-label">Recent proposals</span><span class="metric-value">{{.OperationsLanding.ProposalReviewCount}}</span></a>
  </div>
</section>

<section class="plain-section">
  <div class="eyebrow">Route directory</div>
  <div class="route-list">
    <a href="/app/operations-feed">Durable feed</a>
    <a href="/app/agent-chat">Coordinator chat</a>
    <a href="/app/review/inbound-requests?status=queued">Queued requests</a>
    <a href="/app/review/approvals?status=pending">Pending approvals</a>
    <a href="/app/review/proposals">Recent proposals</a>
  </div>
  <form method="post" action="/app/agent/process-next-queued-inbound-request" class="page-actions">
    <div class="button-row">
      <button type="submit">Process next queued request</button>
    </div>
  </form>
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_review_landing"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review"
  "title" "Review route families"
  "body" "Open the exact review list you need."
)}}

<section class="plain-section">
  <div class="eyebrow">Current workflow links</div>
  <div class="metric-list">
    <a href="/app/review/inbound-requests" class="metric-link"><span class="metric-label">Inbound requests</span><span class="metric-value">{{.ReviewLanding.InboundRequestCount}}</span></a>
    <a href="/app/review/proposals" class="metric-link"><span class="metric-label">Processed proposals</span><span class="metric-value">{{.ReviewLanding.ProposalCount}}</span></a>
    <a href="/app/review/approvals?status=pending" class="metric-link"><span class="metric-label">Pending approvals</span><span class="metric-value">{{len .ReviewLanding.PendingApprovals}}</span></a>
  </div>
</section>

<section class="plain-section">
  <div class="eyebrow">Primary queues</div>
  <div class="route-list">
    <a href="/app/review/inbound-requests">Inbound requests</a>
    <a href="/app/review/proposals">Proposals</a>
    <a href="/app/review/approvals">Approvals</a>
  </div>
</section>

<section class="plain-section">
  <div class="eyebrow">Downstream review</div>
  <div class="route-list">
    <a href="/app/review/documents">Documents</a>
    <a href="/app/review/accounting">Accounting</a>
    <a href="/app/inventory">Inventory</a>
    <a href="/app/review/work-orders">Work orders</a>
    <a href="/app/review/audit">Audit</a>
  </div>
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_inventory_landing"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Inventory"
  "title" "Inventory review bundle"
  "body" "Open the exact inventory workflow or list you need."
)}}

<section class="plain-section">
  <div class="eyebrow">Current workflow links</div>
  <div class="metric-list">
    <a href="/app/review/inventory" class="metric-link"><span class="metric-label">Stock rows</span><span class="metric-value">{{len .InventoryLanding.Stock}}</span></a>
    <a href="/app/review/inventory?only_pending_execution=true#reconciliation" class="metric-link"><span class="metric-label">Pending execution</span><span class="metric-value">{{.InventoryLanding.PendingExecutionCount}}</span></a>
    <a href="/app/review/inventory?only_pending_accounting=true#reconciliation" class="metric-link"><span class="metric-label">Pending accounting</span><span class="metric-value">{{.InventoryLanding.PendingAccountingCount}}</span></a>
  </div>
</section>

<section class="plain-section">
  <div class="eyebrow">Route directory</div>
  <div class="route-list">
    <a href="/app/review/inventory">Inventory review</a>
    <a href="/app/review/inventory?only_pending_execution=true#reconciliation">Execution exceptions</a>
    <a href="/app/review/inventory?only_pending_accounting=true#reconciliation">Accounting exceptions</a>
    <a href="/app/review/work-orders">Work orders</a>
  </div>
</section>

{{if .InventoryLanding.Stock}}
<section class="plain-section">
  <div class="eyebrow">Exact inventory drill-down</div>
  <div class="route-list">
    {{range .InventoryLanding.Stock}}
    <a href="{{inventoryItemHref .ItemID}}">{{.ItemSKU}}</a>
    <a href="{{inventoryLocationHref .LocationID}}">{{.LocationCode}}</a>
    {{end}}
  </div>
</section>
{{end}}

{{if .InventoryLanding.Reconciliation}}
<section class="plain-section">
  <div class="eyebrow">Exact movement drill-down</div>
  <div class="route-list">
    {{range .InventoryLanding.Reconciliation}}
    <a href="{{inventoryMovementHref .MovementID}}">{{.MovementNumber}}</a>
    {{end}}
  </div>
</section>
{{end}}

{{template "web_shell_end" .}}
{{end}}

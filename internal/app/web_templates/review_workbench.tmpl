{{define "web_inbound_requests"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Inbound-request review"
  "body" "Filter by request state or exact REQ continuity without losing processed, completed, failed, or lifecycle context."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Browse request intake without breaking exact continuity</h2>
    </div>
    <a href="/app/operations-feed" class="pill-link secondary">Open operations feed</a>
  </div>
  <form method="get" action="/app/review/inbound-requests" class="filter-grid">
    <label>
      Status
      <input type="text" name="status" value="{{.InboundRequests.Status}}" placeholder="queued, processed, failed">
    </label>
    <label>
      Request reference
      <input type="text" name="request_reference" value="{{.InboundRequests.RequestReference}}" placeholder="REQ-000123">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/inbound-requests" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="page-header">
  <div class="eyebrow">Request status summary</div>
  <p>Current filtered request counts stay visible before the exact table so operators can branch into lifecycle work, failures, or completed outcomes deliberately.</p>
</section>

<section class="status-grid">
  {{if .InboundRequests.StatusSummary}}
    {{range .InboundRequests.StatusSummary}}
      {{template "web_summary_card" (dict
        "label" .Status
        "value" .RequestCount
        "body" (printf "%d messages / %d attachments" .MessageCount .AttachmentCount)
        "action_href" (inboundRequestsHref .Status "")
        "action_label" (dashboardStatusAction .Status)
      )}}
    {{end}}
  {{else}}
    {{template "web_empty_state" (dict "title" "No request summary available." "body" "Status counts will appear here once inbound review data is available for this operator." )}}
  {{end}}
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inbound requests</div>
      <h2>Exact request continuity stays primary</h2>
      <p class="compact-copy">Row actions stay constrained to the next useful continuity hop instead of flattening every downstream surface into one table.</p>
    </div>
  </div>
  {{if .InboundRequests.Requests}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Request</th>
          <th>Status</th>
          <th>Context</th>
          <th>Updated</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .InboundRequests.Requests}}
        <tr>
          <td><a href="{{inboundRequestHref .RequestReference}}">{{.RequestReference}}</a></td>
          <td><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></td>
          <td>
            {{if .FailureReason}}{{.FailureReason}}
            {{else if .CancellationReason}}{{.CancellationReason}}
            {{else}}{{.Channel}} with {{.MessageCount}} messages and {{.AttachmentCount}} attachments{{end}}
          </td>
          <td>{{formatTime .UpdatedAt}}</td>
          <td class="inline-links">
            <a href="{{inboundRequestHref .RequestReference}}">Manage lifecycle</a>
            <a href="{{inboundRequestHref .RequestReference}}">{{dashboardRequestAction .Status}}</a>
            {{if .LastRunID.Valid}}<a href="{{inboundSectionHref (print "run:" .LastRunID.String) (runSectionID .LastRunID.String)}}">AI run</a>{{end}}
            {{if .LastRecommendationID.Valid}}<a href="{{proposalDetailHref .LastRecommendationID.String}}">{{if .LastRecommendationStatus.Valid}}{{.LastRecommendationStatus.String}}{{else}}Proposal{{end}}</a>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No inbound requests match the current filters." "body" "Use the dedicated intake page or clear the filters to repopulate the workbench." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_approvals"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Approval review"
  "body" "Keep queue state, exact approval continuity, and upstream request or proposal links in one calmer review surface."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Browse exact approvals or narrow one queue</h2>
    </div>
  </div>
  <form method="get" action="/app/review/approvals" class="filter-grid">
    <label>
      Approval ID
      <input type="text" name="approval_id" value="{{.Approvals.ApprovalID}}" placeholder="approval-123">
    </label>
    <label>
      Queue code
      <input type="text" name="queue_code" value="{{.Approvals.QueueCode}}" placeholder="finance_review">
    </label>
    <label>
      Status
      <input type="text" name="status" value="{{.Approvals.Status}}" placeholder="pending, approved, rejected">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/approvals" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Approval queue</div>
      <h2>Queue rows stay focused on the decision seam</h2>
    </div>
  </div>
  {{if .Approvals.Approvals}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Approval</th>
          <th>Queue</th>
          <th>Document</th>
          <th>Requested</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Approvals.Approvals}}
        <tr>
          <td><a href="{{approvalReviewHref .ApprovalID}}">{{.ApprovalID}}</a></td>
          <td><span class="status-pill {{statusClass .ApprovalStatus}}">{{.ApprovalStatus}}</span><div class="meta">{{.QueueCode}} / {{.QueueStatus}}</div></td>
          <td>{{if .DocumentID}}<a href="/app/review/documents/{{.DocumentID}}">{{.DocumentTitle}}</a>{{else}}{{.DocumentTitle}}{{end}}<div class="meta">{{.DocumentTypeCode}} / {{.DocumentStatus}}</div></td>
          <td>{{formatTime .RequestedAt}}</td>
          <td class="inline-links">
            <a href="{{approvalReviewHref .ApprovalID}}">Open exact approval</a>
            <a href="{{documentReviewHref .DocumentID}}">Open document</a>
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            {{if .RecommendationID.Valid}}<a href="{{proposalDetailHref .RecommendationID.String}}">{{if .RecommendationStatus.Valid}}{{.RecommendationStatus.String}}{{else}}Proposal{{end}}</a>{{end}}
            {{if .JournalEntryID.Valid}}<a href="{{accountingEntryHref .JournalEntryID.String}}">Entry #{{.JournalEntryNumber.Int64}}</a>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No approvals match the current filters." "body" "Queue entries will appear here when proposal review requests explicit approval." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_proposals"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Proposal review"
  "body" "Track the coordinator handoff from exact inbound request reference into proposal, approval, and document continuity."
)}}

<section class="panel section-stack">

{{define "web_head"}}
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{if .Title}}{{.Title}}{{else}}workflow_app{{end}}</title>
  <style>{{template "web_styles" .}}</style>
</head>
{{end}}

{{define "web_shell_start"}}
{{template "web_head" .}}
<body>
  <div class="shell-frame">
    <header class="shell-header">
      <div class="shell-topbar">
        <a href="/app" class="brand-link">
          <span class="brand-mark">WA</span>
          <span class="brand-copy">
            <strong>Workflow App</strong>
            <span>Persist-first operator shell</span>
          </span>
        </a>

        {{if .Session}}
        <div class="session-tools">
          <div class="session-pill">
            <strong>{{.Session.UserEmail}}</strong>
            <span>{{.Session.OrgSlug}} / {{.Session.RoleCode}}</span>
          </div>

          <details class="utility-menu">
            <summary>User</summary>
            <div class="utility-menu-panel">
              <form method="get" action="/app/routes" class="compact-form">
                <label>
                  Search routes
                  <input type="text" name="q" placeholder="pending approvals, failed requests, inventory...">
                </label>
                <div class="button-row">
                  <button type="submit" class="secondary">Open catalog</button>
                  <a href="/app/settings" class="{{navClass .ActivePath "/app/settings"}}">Settings</a>
                  <a href="/app/routes" class="{{navClass .ActivePath "/app/routes"}}">Catalog</a>
                </div>
              </form>
              {{if eq .Session.RoleCode "admin"}}
              <div class="button-row">
                <a href="/app/admin" class="{{navClass .ActivePath "/app/admin"}}">Admin</a>
              </div>
              {{end}}
              <form method="post" action="/app/logout">
                <button type="submit" class="secondary">Sign out</button>
              </form>
            </div>
          </details>
        </div>
        {{else}}
        <div class="session-tools">
          <a href="/app/login" class="pill-link secondary">Sign in</a>
        </div>
        {{end}}
      </div>

      {{if .Session}}
      <div class="shell-nav">
        <div class="nav-band">
          <div class="nav-band-label">Workflow destinations</div>
          <div class="nav-bubbles">
            <a href="/app" class="{{navSectionClass .ActivePath "home"}}">Home</a>
            <a href="/app/submit-inbound-request" class="{{navSectionClass .ActivePath "intake"}}">Intake</a>
            <a href="/app/operations" class="{{navSectionClass .ActivePath "operations"}}">Operations</a>
            <a href="/app/review" class="{{navSectionClass .ActivePath "review"}}">Review</a>
            <a href="/app/inventory" class="{{navSectionClass .ActivePath "inventory"}}">Inventory</a>
            <a href="/app/review/inbound-requests" class="{{navClass .ActivePath "/app/review/inbound-requests"}}">Inbound requests</a>
            <a href="/app/review/proposals" class="{{navClass .ActivePath "/app/review/proposals"}}">Proposals</a>
            <a href="/app/review/approvals" class="{{navClass .ActivePath "/app/review/approvals"}}">Approvals</a>
          </div>
        </div>
      </div>
      {{end}}
    </header>

    <main class="shell-main">
      <div class="page-stack">
        {{template "web_flash" .}}
{{end}}

{{define "web_shell_end"}}
      </div>
    </main>
  </div>
</body>
</html>
{{end}}

{{define "web_public_start"}}
{{template "web_head" .}}
<body class="login-shell">
  <div class="public-shell">
    <div class="public-topbar">
      <a href="/app/login" class="brand-link">
        <span class="brand-mark">WA</span>
        <span class="brand-copy">
          <strong>Workflow App</strong>
          <span>Browser session entry</span>
        </span>
      </a>
    </div>
    {{template "web_flash" .}}
{{end}}

{{define "web_public_end"}}
  </div>
</body>
</html>
{{end}}

{{define "web_flash"}}
{{if .Notice}}
<div class="flash-stack">
  <div class="flash notice">{{.Notice}}</div>
</div>
{{end}}
{{if .Error}}
<div class="flash-stack">
  <div class="flash error">{{.Error}}</div>
</div>
{{end}}
{{end}}

{{define "web_page_header"}}
<section class="page-header">
  {{if index . "eyebrow"}}<div class="eyebrow">{{index . "eyebrow"}}</div>{{end}}
  <h1>{{index . "title"}}</h1>
  {{if index . "body"}}<p>{{index . "body"}}</p>{{end}}
</section>
{{end}}

{{define "web_summary_card"}}
<section class="summary-card">
  {{if index . "label"}}<div class="eyebrow">{{index . "label"}}</div>{{end}}
  {{if index . "value"}}<div class="count">{{index . "value"}}</div>{{end}}
  {{if index . "body"}}<div class="meta">{{index . "body"}}</div>{{end}}
  {{if and (index . "action_href") (index . "action_label")}}
  <div class="meta"><a href="{{index . "action_href"}}">{{index . "action_label"}}</a></div>
  {{end}}
</section>
{{end}}

{{define "web_empty_state"}}
<div class="empty-state">
  <h3>{{index . "title"}}</h3>
  <p>{{index . "body"}}</p>
</div>
{{end}}

{{define "web_detail_block"}}
<div class="detail-block">
  <div class="eyebrow">{{index . "label"}}</div>
  <div>{{index . "value"}}</div>
  {{if index . "body"}}<div class="meta">{{index . "body"}}</div>{{end}}
</div>
{{end}}

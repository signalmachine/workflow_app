package pages

import (
	"fmt"
	"accounting-agent/internal/app"
	"accounting-agent/web/templates/layouts"

	"github.com/shopspring/decimal"
)

// ProductsList renders the products/inventory catalog page.
templ ProductsList(d layouts.AppLayoutData, result *app.ProductListResult, stock *app.StockResult) {
	@layouts.AppLayout(d) {
		<div class="max-w-5xl space-y-4">
			<!-- Page header -->
			<div class="flex items-center justify-between flex-wrap gap-3">
				<div>
					<h1 class="text-2xl font-bold text-slate-900">Products</h1>
					<p class="text-sm text-slate-500 mt-0.5">{ fmt.Sprintf("%d", len(result.Products)) } products in catalog</p>
				</div>
				<a
					href="/inventory/stock"
					class="px-3 py-1.5 text-sm bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg transition-colors"
				>
					📊 View Stock Levels
				</a>
			</div>
			<!-- Table -->
			<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
				if len(result.Products) == 0 {
					<div class="empty-state">
						<div class="empty-state-icon">🏷️</div>
						<div class="empty-state-title">No products found</div>
					</div>
				} else {
					<table class="data-table">
						<thead>
							<tr>
								<th class="w-24">Code</th>
								<th>Name</th>
								<th class="w-20 hidden sm:table-cell">Unit</th>
								<th class="w-32">Unit Price</th>
								<th class="w-28 hidden md:table-cell">On Hand</th>
							</tr>
						</thead>
						<tbody>
							for _, p := range result.Products {
								<tr>
									<td class="font-mono text-xs text-slate-500">{ p.Code }</td>
									<td>
										<div class="font-medium">{ p.Name }</div>
										if p.Description != "" {
											<div class="text-xs text-slate-500 mt-0.5">{ p.Description }</div>
										}
									</td>
									<td class="text-slate-500 hidden sm:table-cell">{ p.Unit }</td>
									<td class="num">{ p.UnitPrice.StringFixed(2) }</td>
									<td class="num text-slate-700 hidden md:table-cell">
										{ plProductOnHand(stock, p.Code).StringFixed(2) }
									</td>
								</tr>
							}
						</tbody>
					</table>
				}
			</div>
		</div>
	}
}

func plProductOnHand(stock *app.StockResult, code string) decimal.Decimal {
	if stock == nil {
		return decimal.Zero
	}
	for _, s := range stock.Levels {
		if s.ProductCode == code {
			return s.OnHand
		}
	}
	return decimal.Zero
}

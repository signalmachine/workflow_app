      Proposal ID
      <input type="text" name="recommendation_id" value="{{.Proposals.RecommendationID}}" placeholder="rec-123">
    </label>
    <label>
      Status
      <input type="text" name="status" value="{{.Proposals.Status}}" placeholder="approval_requested">
    </label>
    <label>
      Request reference
      <input type="text" name="request_reference" value="{{.Proposals.RequestReference}}" placeholder="REQ-000123">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/proposals" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="page-header">

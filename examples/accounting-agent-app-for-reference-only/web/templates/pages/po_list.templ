package pages

import (
	"fmt"
	"accounting-agent/internal/app"
	"accounting-agent/web/templates/layouts"
)

// POList renders the purchase orders list page.
templ POList(d layouts.AppLayoutData, result *app.PurchaseOrdersResult, statusFilter string) {
	@layouts.AppLayout(d) {
		<div class="space-y-5">
			<!-- Header -->
			<div class="flex items-center justify-between">
				<div>
					<h1 class="text-2xl font-bold text-slate-900">Purchase Orders</h1>
					<p class="text-sm text-slate-500 mt-0.5">
						{ fmt.Sprintf("%d order(s)", len(result.Orders)) }
					</p>
				</div>
				<a
					href="/purchases/orders/new"
					class="px-4 py-2 text-sm font-medium bg-slate-800 hover:bg-slate-700 text-white rounded-lg transition-colors"
				>
					+ New PO
				</a>
			</div>
			<!-- Status filter pills -->
			<div class="flex flex-wrap gap-2">
				@poStatusPill("", statusFilter, "All")
				@poStatusPill("DRAFT", statusFilter, "Draft")
				@poStatusPill("APPROVED", statusFilter, "Approved")
				@poStatusPill("RECEIVED", statusFilter, "Received")
				@poStatusPill("INVOICED", statusFilter, "Invoiced")
				@poStatusPill("PAID", statusFilter, "Paid")
			</div>
			<!-- Table -->
			<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
				if len(result.Orders) == 0 {
					<div class="empty-state">
						<div class="empty-state-icon">📦</div>
						<div class="empty-state-title">No purchase orders</div>
						<div class="empty-state-text">
							<a href="/purchases/orders/new" class="text-slate-700 underline hover:text-slate-900">Create your first PO</a>
						</div>
					</div>
				} else {
					<table class="data-table">
						<thead>
							<tr>
								<th>PO Number</th>
								<th>Vendor</th>
								<th class="hidden sm:table-cell">Date</th>
								<th>Status</th>
								<th class="hidden md:table-cell">Total</th>
								<th></th>
							</tr>
						</thead>
						<tbody>
							for _, po := range result.Orders {
								<tr>
									<td class="font-mono font-medium">
										if po.PONumber != nil {
											{ *po.PONumber }
										} else {
											<span class="text-slate-400">DRAFT-{ fmt.Sprintf("%d", po.ID) }</span>
										}
									</td>
									<td>
										<div class="font-medium">{ po.VendorName }</div>
										<div class="text-xs text-slate-400 font-mono">{ po.VendorCode }</div>
									</td>
									<td class="text-slate-500 hidden sm:table-cell">{ po.PODate }</td>
									<td>
										@poStatusBadge(po.Status)
									</td>
									<td class="num text-slate-700 hidden md:table-cell">
										{ po.TotalTransaction.StringFixed(2) }
									</td>
									<td class="text-right">
										<a href={ templ.SafeURL(fmt.Sprintf("/purchases/orders/%d", po.ID)) } class="text-sm text-slate-500 hover:text-slate-800 transition-colors">
											View →
										</a>
									</td>
								</tr>
							}
						</tbody>
					</table>
				}
			</div>
		</div>
	}
}

// poStatusPill renders a status filter pill.
templ poStatusPill(status, active, label string) {
	<a
		href={ templ.SafeURL(poPillURL(status)) }
		class={ poPillClass(status, active) }
	>
		{ label }
	</a>
}

// poStatusBadge renders a colored status badge.
templ poStatusBadge(status string) {
	<span class={ poBadgeClass(status) }>
		{ status }
	</span>
}

func poPillURL(status string) string {
	if status == "" {
		return "/purchases/orders"
	}
	return "/purchases/orders?status=" + status
}

func poPillClass(status, active string) string {
	if status == active {
		return "px-3 py-1.5 text-xs font-semibold rounded-full bg-slate-800 text-white"
	}
	return "px-3 py-1.5 text-xs font-semibold rounded-full bg-white border border-gray-200 text-slate-600 hover:bg-gray-50 transition-colors"
}

func poBadgeClass(status string) string {
	switch status {
	case "DRAFT":
		return "badge badge-draft"
	case "APPROVED":
		return "badge badge-approved"
	case "RECEIVED":
		return "badge badge-received"
	case "INVOICED":
		return "badge badge-invoiced"
	case "PAID":
		return "badge badge-paid"
	default:
		return "badge badge-draft"
	}
}

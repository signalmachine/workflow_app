{{define "web_styles"}}
:root {
  --bg: #e9eef2;
  --bg-deep: #dbe5ea;
  --surface: rgba(252, 251, 247, 0.94);
  --surface-strong: rgba(255, 255, 255, 0.98);
  --surface-muted: #eef2f4;
  --surface-accent: #eff4f8;
  --shell-ink: #1d3343;
  --shell-ink-strong: #122533;
  --ink: #18232d;
  --ink-soft: #5a6975;
  --ink-faint: #7a8894;
  --line: rgba(96, 117, 132, 0.26);
  --line-strong: rgba(59, 80, 95, 0.42);
  --accent: #2f617f;
  --accent-strong: #1d4359;
  --accent-soft: #dce9f2;
  --accent-faint: rgba(47, 97, 127, 0.10);
  --good: #21634a;
  --good-soft: #e6f2ec;
  --bad: #a64553;
  --bad-soft: #f9ebee;
  --neutral: #4d6274;
  --neutral-soft: #e7edf2;
  --shadow-sm: 0 8px 18px rgba(18, 37, 51, 0.06);
  --shadow: 0 18px 42px rgba(18, 37, 51, 0.10);
  --radius-xl: 24px;
  --radius-lg: 18px;
  --radius-md: 14px;
  --radius-sm: 999px;
  --max-width: 1320px;
  --font-sans: "IBM Plex Sans", "Segoe UI", sans-serif;
  --font-mono: "IBM Plex Mono", "SFMono-Regular", monospace;
}

* { box-sizing: border-box; }

html,
body {
  margin: 0;
  padding: 0;
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.72), transparent 32%),
    radial-gradient(circle at top right, rgba(47, 97, 127, 0.10), transparent 28%),
    linear-gradient(180deg, #eef3f5 0%, var(--bg) 42%, var(--bg-deep) 100%);
  color: var(--ink);
  font-family: var(--font-sans);
}

body {
  min-height: 100vh;
  position: relative;
}

body::before {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
  background:
    linear-gradient(rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.08)),
    repeating-linear-gradient(
      90deg,
      transparent 0,
      transparent 68px,
      rgba(24, 35, 45, 0.025) 68px,
      rgba(24, 35, 45, 0.025) 69px
    );
  opacity: 0.7;
}

a {
  color: var(--accent-strong);
  text-decoration: none;
}

a:hover {
  text-decoration: underline;
}

.pill-link,
.button-link,
button,
input[type="submit"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 42px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  background: linear-gradient(180deg, #396f90 0%, var(--accent-strong) 100%);
  color: #f8fbfd;
  font: inherit;
  font-weight: 600;
  letter-spacing: 0.01em;
  text-decoration: none;
  cursor: pointer;
  box-shadow: 0 12px 24px rgba(29, 67, 89, 0.16);
  transition: transform 140ms ease, box-shadow 140ms ease, background 140ms ease, border-color 140ms ease;
}

.pill-link:hover,
.button-link:hover,
button:hover,
input[type="submit"]:hover {
  transform: translateY(-1px);
  box-shadow: 0 16px 28px rgba(29, 67, 89, 0.20);
  text-decoration: none;
}

.pill-link.secondary,
.button-link.secondary,
button.secondary,
input[type="submit"].secondary {
  background: var(--surface-strong);
  color: var(--accent-strong);
  border-color: var(--line);
  box-shadow: none;
}

.button-row,
.action-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.flash-stack {
  display: grid;
  gap: 12px;
}

.flash {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  border: 1px solid var(--line);
  background: var(--surface-strong);
  box-shadow: var(--shadow-sm);
}

.flash.notice {
  border-color: rgba(73, 122, 173, 0.32);
  background: #edf5ff;
}

.flash.error {
  border-color: rgba(166, 69, 83, 0.28);
  background: #fff3f5;
}

.public-shell {
  width: min(760px, calc(100vw - 32px));
  margin: 0 auto;
  padding: 28px 0 46px;
}

.shell-frame {
  width: min(var(--max-width), calc(100vw - 32px));
  margin: 0 auto;
  padding: 20px 0 38px;
  display: grid;
  gap: 18px;
  position: relative;
  z-index: 1;
}

.shell-header {
  display: grid;
  gap: 12px;
}

.session-meta,
.panel-subtitle,
.meta,
.eyebrow,
.section-copy {
  color: var(--ink-soft);
}

.shell-topbar,
.public-topbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  min-height: 66px;
  padding: 12px 16px;
  border: 1px solid rgba(18, 37, 51, 0.18);
  border-radius: var(--radius-xl);
  background:
    linear-gradient(135deg, rgba(18, 37, 51, 0.97) 0%, rgba(32, 61, 78, 0.95) 62%, rgba(42, 80, 102, 0.93) 100%);
  box-shadow: var(--shadow);
}

.brand-link {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  color: #f4f7fa;
  text-decoration: none;
}

.brand-link:hover {
  text-decoration: none;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 14px;
  background: linear-gradient(180deg, #f1f4e8 0%, #dfe8d8 100%);
  border: 1px solid rgba(223, 232, 216, 0.7);
  color: var(--shell-ink-strong);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
}

.brand-copy {
  display: grid;
  gap: 2px;
}

.brand-copy strong {
  font-size: 1.02rem;
  line-height: 1.05;
  letter-spacing: 0.01em;
}

.brand-copy span {
  color: rgba(235, 241, 245, 0.78);
  font-size: 0.85rem;
}

.session-tools {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.session-pill {
  display: grid;
  gap: 2px;
  padding: 8px 12px;
  border-radius: 14px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.14);
  color: #f5f8fb;
  line-height: 1.25;
}

.session-pill span {
  color: rgba(235, 241, 245, 0.72);
  font-size: 0.83rem;
}

.shell-nav,
.panel,
.table-card,
.summary-card,
.detail-block,
.feed-item,
.result-card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
}

.shell-nav {
  padding: 12px 14px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 10px 14px;
  background:
    linear-gradient(180deg, rgba(253, 252, 249, 0.98) 0%, rgba(245, 247, 248, 0.96) 100%);
}

.nav-band {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px 16px;
}

.nav-band-label {
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-faint);
}

.nav-bubbles {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 10px;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  min-height: 38px;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  color: var(--accent-strong);
  text-decoration: none;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(96, 117, 132, 0.22);
  font-weight: 600;
  font-size: 0.91rem;
  transition: transform 140ms ease, border-color 140ms ease, background 140ms ease, box-shadow 140ms ease;
}

.nav-link:hover {
  text-decoration: none;
  transform: translateY(-1px);
  border-color: rgba(47, 97, 127, 0.32);
  box-shadow: 0 8px 18px rgba(29, 67, 89, 0.08);
}

.nav-link.is-active {
  background: linear-gradient(180deg, #2f617f 0%, #244f68 100%);
  border-color: rgba(29, 67, 89, 0.65);
  color: #f5f8fb;
  box-shadow: 0 10px 20px rgba(29, 67, 89, 0.16);
}

.utility-menu {
  position: relative;
}

.utility-menu summary {
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 38px;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  border: 1px solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.10);
  color: #f5f8fb;
  font-weight: 600;
}

.utility-menu summary::-webkit-details-marker {
  display: none;
}

.utility-menu[open] summary {
  background: rgba(255, 255, 255, 0.16);
  border-color: rgba(255, 255, 255, 0.30);
}

.utility-menu-panel {
  display: grid;
  gap: 12px;
  margin-top: 12px;
  padding: 14px;
  border-radius: 16px;
  border: 1px solid rgba(18, 37, 51, 0.14);
  background: rgba(252, 251, 247, 0.98);
  box-shadow: 0 18px 42px rgba(18, 37, 51, 0.16);
}

.shell-main {
  display: grid;
  gap: 18px;
}

.page-stack {
  display: grid;
  gap: 18px;
}

.page-header,
.panel,
.result-card,
.feed-item,
.table-card {
  padding: 20px 22px;
}

.page-header {
  display: grid;
  gap: 10px;
  padding: 4px 2px 0;
  background: transparent;
  border: 0;
  box-shadow: none;
  max-width: 920px;
}

.eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.page-header h1,
.hero-card h2,
.panel h2,
.panel h3,
.table-card h2,
.table-card h3,
.summary-card h3,
.result-card h2 {
  margin: 0;
  letter-spacing: -0.03em;
}

.page-header h1 {
  font-size: clamp(1.9rem, 3vw, 2.9rem);
  line-height: 0.98;
  max-width: 14ch;
}

.page-header p,
.panel p,
.table-card p,
.result-card p {
  margin: 0;
  line-height: 1.58;
}

.page-header p {
  font-size: 1.02rem;
  color: var(--ink-soft);
  max-width: 62ch;
}

.two-up,
.three-up,
.status-grid {
  display: grid;
  gap: 16px;
}

.two-up {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-up {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.status-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.summary-card,
.detail-block {
  padding: 16px 18px;
}

.summary-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(243, 247, 249, 0.95) 100%);
}

.summary-card::before {
  content: "";
  position: absolute;
  inset: 0 auto 0 0;
  width: 4px;
  background: linear-gradient(180deg, var(--accent) 0%, rgba(47, 97, 127, 0.16) 100%);
}

.summary-card .count {
  font-size: 1.7rem;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.summary-card .meta,
.detail-block .meta {
  margin-top: 8px;
}

.result-card {
  background: rgba(255, 255, 255, 0.98);
}

.table-card {
  display: grid;
  gap: 14px;
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid rgba(96, 117, 132, 0.18);
  border-radius: 18px;
  background: var(--surface-strong);
}

table {
  width: 100%;
  border-collapse: collapse;
}

.table-wrap > table {
  min-width: 640px;
}

th,
td {
  padding: 14px 16px;
  border-bottom: 1px solid rgba(96, 117, 132, 0.16);
  text-align: left;
  vertical-align: top;
}

th {
  font-size: 0.79rem;
  text-transform: uppercase;
  letter-spacing: 0.10em;
  color: var(--ink-faint);
  background: linear-gradient(180deg, #eef3f6 0%, #e8eef2 100%);
}

tbody tr:nth-child(even) td {
  background: rgba(239, 244, 247, 0.45);
}

tbody tr:hover td {
  background: rgba(220, 233, 242, 0.42);
}

tr:last-child td { border-bottom: 0; }

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: var(--radius-sm);
  font-size: 0.76rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--neutral-soft);
  color: var(--neutral);
}

.status-good { background: var(--good-soft); color: var(--good); }
.status-bad { background: var(--bad-soft); color: var(--bad); }
.status-neutral { background: var(--neutral-soft); color: var(--neutral); }

.field-grid {
  display: grid;
  gap: 14px;
}

.filter-grid {
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  align-items: end;
}

.filter-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.field-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

label {
  display: grid;
  gap: 8px;
  font-weight: 600;
  color: var(--ink-soft);
}

input[type="text"],
input[type="email"],
input[type="password"],
input[type="date"],
textarea,
select,
input[type="file"] {
  width: 100%;
  padding: 11px 12px;
  border-radius: 12px;
  border: 1px solid rgba(96, 117, 132, 0.22);
  background: rgba(255, 255, 255, 0.95);
  color: var(--ink);
  font: inherit;
  transition: border-color 120ms ease, box-shadow 120ms ease, background 120ms ease;
}

input[type="text"]:focus,
input[type="email"]:focus,
input[type="password"]:focus,
input[type="date"]:focus,
textarea:focus,
select:focus,
input[type="file"]:focus {
  outline: none;
  border-color: rgba(47, 97, 127, 0.52);
  box-shadow: 0 0 0 4px rgba(47, 97, 127, 0.10);
  background: #fff;
}

textarea { min-height: 180px; resize: vertical; }

.feed-list,
.card-stack,
.detail-grid,
.review-link-list,
.catalog-grid,
.directory-list,
.route-list,
.metric-list,
.summary-strip,
.surface-stack {
  display: grid;
  gap: 12px;
}

.catalog-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.summary-strip {
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.directory-list a {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid rgba(96, 117, 132, 0.18);
  background: rgba(255, 255, 255, 0.82);
  font-weight: 600;
}

.directory-list a::after {
  content: "Open";
  color: var(--ink-soft);
  font-size: 0.80rem;
  font-weight: 500;
}

.directory-list a:hover {
  text-decoration: none;
  background: var(--accent-soft);
}

.plain-section {
  display: grid;
  gap: 10px;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.plain-section h2,
.plain-section p,
.plain-section ul {
  margin: 0;
}

.route-list,
.metric-list {
  gap: 10px;
}

.route-list a,
.metric-link {
  color: var(--accent-strong);
  text-decoration: none;
}

.route-link-card,
.metric-link {
  display: grid;
  gap: 6px;
  width: 100%;
  max-width: 100%;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(96, 117, 132, 0.18);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(244, 247, 248, 0.94) 100%);
  box-shadow: var(--shadow-sm);
  transition: transform 140ms ease, border-color 140ms ease, box-shadow 140ms ease, background 140ms ease;
}

.route-link-card {
  position: relative;
  align-content: start;
  color: var(--ink);
  font-weight: 700;
  line-height: 1.35;
}

.route-link-card:hover,
.metric-link:hover {
  text-decoration: none;
  transform: translateY(-1px);
  border-color: rgba(47, 97, 127, 0.30);
  box-shadow: 0 14px 28px rgba(29, 67, 89, 0.10);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(236, 243, 247, 0.96) 100%);
}

.route-link-card::after {
  content: attr(data-summary);
  display: block;
  margin-top: 6px;
  color: var(--ink-soft);
  font-size: 0.95rem;
  font-weight: 400;
  line-height: 1.48;
  max-width: 70ch;
}

.route-link-card::before {
  content: attr(data-kicker);
  display: block;
  margin-bottom: 6px;
  color: var(--ink-faint);
  font-size: 0.74rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.route-link-card[data-kicker=""]::before,
.route-link-card:not([data-kicker])::before {
  display: none;
}

.route-link-card .route-link-title {
  display: none;
}

.route-link-card.route-link-compact {
  padding: 12px 14px;
}

.route-link-card.route-link-compact::after {
  font-size: 0.90rem;
}

.metric-link {
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: baseline;
  gap: 10px 14px;
  color: var(--ink);
  font-weight: 700;
}

.metric-link::after {
  content: attr(data-value);
  color: var(--accent-strong);
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: -0.03em;
}

.surface-stack {
  grid-template-columns: minmax(0, 1fr);
}

.page-actions,
.compact-form {
  display: grid;
  gap: 12px;
}

.detail-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.feed-item {
  display: grid;
  gap: 12px;
}

.feed-head {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: space-between;
  align-items: baseline;
}

.empty-state {
  padding: 18px;
  border-radius: 16px;
  border: 1px dashed var(--line-strong);
  background: rgba(243, 247, 249, 0.86);
}

.empty-state h3 {
  margin: 0 0 8px;
}

.section-stack {
  display: grid;
  gap: 18px;
}

.section-head {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12px;
  align-items: start;
}

.section-head h2,
.section-head p {
  margin: 0;
}

pre {
  margin: 0;
  padding: 16px;
  border-radius: 18px;
  background: linear-gradient(180deg, #f4f0e8 0%, #efebe0 100%);
  border: 1px solid rgba(96, 117, 132, 0.18);
  overflow-x: auto;
  font-family: var(--font-mono);
  font-size: 0.9rem;
  line-height: 1.58;
  color: #283642;
}

details {
  display: grid;
  gap: 12px;
}

summary {
  cursor: pointer;
  font-weight: 600;
}

.inline-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 14px;
}

.inline-links a {
  font-weight: 600;
}

.compact-copy {
  font-size: 0.95rem;
}

.login-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14px;
  align-items: start;
}

.login-panel {
  padding: 28px;
}

.login-shell {
  min-height: 100vh;
}

.login-shell .public-shell {
  padding-top: 42px;
}

.compact-intro {
  display: grid;
  gap: 10px;
  padding: 18px 20px;
  border: 1px solid rgba(96, 117, 132, 0.18);
  border-radius: var(--radius-xl);
  background: linear-gradient(180deg, rgba(252, 251, 247, 0.94) 0%, rgba(243, 247, 249, 0.92) 100%);
  box-shadow: var(--shadow-sm);
}

.compact-intro h2,
.compact-intro p {
  margin: 0;
}

.workflow-page {
  display: grid;
  gap: 16px;
}

.workflow-page .panel,
.workflow-page .table-card,
.workflow-page .result-card {
  width: 100%;
}

@media (max-width: 1080px) {
  .three-up,
  .two-up,
  .login-grid,
  .field-grid.two {
    grid-template-columns: 1fr;
  }

  .page-header h1 {
    max-width: none;
  }
}

@media (max-width: 720px) {
  .public-shell,
  .shell-frame {
    width: min(100vw - 18px, var(--max-width));
  }

  .shell-topbar,
  .public-topbar {
    padding: 14px;
  }

  .shell-nav,
  .panel,
  .table-card,
  .result-card,
  .feed-item,
  .summary-card,
  .detail-block,
  .login-panel {
    padding: 18px;
  }

  th,
  td {
    padding: 12px;
  }

  .nav-bubbles {
    gap: 8px;
  }

  .nav-link,
  .utility-menu summary,
  .session-tools > a {
    width: 100%;
    justify-content: center;
  }

  .shell-topbar,
  .public-topbar,
  .shell-nav,
  .nav-band,
  .session-tools,
  .metric-link {
    align-items: stretch;
  }


{{define "web_inbound_detail"}}
{{template "web_shell_start" .}}
{{with .Detail}}
{{template "web_page_header" (dict
  "eyebrow" "Request detail"
  "title" (printf "Inbound request %s" .Detail.Request.RequestReference)
  "body" "Review the exact intake record, lifecycle controls, durable evidence, and AI execution trace without losing workflow continuity."
)}}

<section class="hero-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Primary summary</div>
      <h2>{{.Detail.Request.RequestReference}}</h2>
      <p>Status, intake channel, and received timing remain the top-level reading order for request continuity.</p>
    </div>
    <div class="action-group">
      <a href="{{inboundRequestReview .Detail.Request.RequestReference}}" class="pill-link">Filtered request review</a>
      <a href="/app/review/audit?entity_type=ai.inbound_request&amp;entity_id={{.Detail.Request.RequestID}}" class="pill-link secondary">Audit trail</a>
    </div>
  </div>
  <div class="detail-grid">
    <div class="detail-card">
      <div class="eyebrow">Status</div>
      <div><span class="status-pill {{statusClass .Detail.Request.Status}}">{{.Detail.Request.Status}}</span></div>
    </div>
    <div class="detail-card">
      <div class="eyebrow">Channel</div>
      <div>{{.Detail.Request.Channel}}</div>
    </div>
    <div class="detail-card">
      <div class="eyebrow">Origin</div>
      <div>{{.Detail.Request.OriginType}}</div>
    </div>
    <div class="detail-card">
      <div class="eyebrow">Received</div>
      <div>{{formatTime .Detail.Request.ReceivedAt}}</div>
    </div>
  </div>
  {{if .Detail.Request.CancelledAt.Valid}}
  <div class="detail-block">
    <div class="eyebrow">Cancellation</div>
    <div>Cancelled: {{formatTime .Detail.Request.CancelledAt.Time}}{{if .Detail.Request.CancellationReason}} | {{.Detail.Request.CancellationReason}}{{end}}</div>
  </div>
  {{end}}
  {{if .Detail.Request.FailedAt.Valid}}
  <div class="detail-block">
    <div class="eyebrow">Failure</div>
    <div>Failed: {{formatTime .Detail.Request.FailedAt.Time}}{{if .Detail.Request.FailureReason}} | {{.Detail.Request.FailureReason}}{{end}}</div>
  </div>
  {{end}}
  {{if eq .Detail.Request.Status "draft"}}
  <div class="detail-block">
    <div class="eyebrow">Draft controls</div>
    <h3>Edit draft</h3>
    <form method="post" action="/app/inbound-requests" enctype="multipart/form-data" class="field-grid">
      <input type="hidden" name="request_id" value="{{.Detail.Request.RequestID}}">
      <input type="hidden" name="message_id" value="{{.EditableMessageID}}">
      <input type="hidden" name="return_to" value="/app/inbound-requests/{{.Detail.Request.RequestReference}}">
      <input type="hidden" name="channel" value="{{.Detail.Request.Channel}}">
      <label>Submitter label
        <input type="text" name="submitter_label" value="{{.EditableSubmitterLabel}}">
      </label>
      <label>Request message
        <textarea name="message_text" required>{{.EditableMessageText}}</textarea>
      </label>
      <label>Add attachments
        <input type="file" name="attachments" multiple>
      </label>
      <div class="action-group">
        <button type="submit" name="intent" value="save_draft">Save draft</button>
        <button type="submit" name="intent" value="queue">Queue request</button>
      </div>
    </form>
    <form method="post" action="{{inboundActionHref .Detail.Request.RequestID "delete"}}" style="margin-top:12px;">
      <input type="hidden" name="return_to" value="/app/inbound-requests/{{.Detail.Request.RequestReference}}">
      <button type="submit" class="secondary">Delete draft</button>
    </form>
  </div>
  {{else if eq .Detail.Request.Status "queued"}}
  <div class="detail-block">
    <div class="eyebrow">Queued controls</div>
    <h3>Queued request actions</h3>
    <div class="action-group">
      <form method="post" action="{{inboundActionHref .Detail.Request.RequestID "cancel"}}" class="field-grid compact-form">
        <input type="hidden" name="return_to" value="/app/inbound-requests/{{.Detail.Request.RequestReference}}">
        <label>Cancellation reason
          <input type="text" name="reason" placeholder="Cancellation reason">
        </label>
        <button type="submit" class="secondary">Cancel request</button>
      </form>
      <form method="post" action="{{inboundActionHref .Detail.Request.RequestID "amend"}}">
        <input type="hidden" name="return_to" value="/app/inbound-requests/{{.Detail.Request.RequestReference}}">
        <button type="submit">Return to draft</button>
      </form>
    </div>
  </div>
  {{else if eq .Detail.Request.Status "cancelled"}}
  <div class="detail-block">
    <div class="eyebrow">Cancelled controls</div>
    <h3>Cancelled request actions</h3>
    <form method="post" action="{{inboundActionHref .Detail.Request.RequestID "amend"}}">
      <input type="hidden" name="return_to" value="/app/inbound-requests/{{.Detail.Request.RequestReference}}">
      <button type="submit">Amend back to draft</button>
    </form>
  </div>
  {{end}}
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Metadata</div>
      <h2>Persisted request context</h2>
    </div>
  </div>
  <pre>{{prettyJSON .Detail.Request.Metadata}}</pre>
</section>

<div class="two-up">
  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Evidence</div>
        <h2>Messages</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Messages}}
      <div class="detail-block">
        <strong>#{{.MessageIndex}} {{.MessageRole}}</strong>
        <p>{{.TextContent}}</p>
        <div class="meta">{{formatTime .CreatedAt}}</div>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No messages." "body" "Request messages will appear here once intake content exists." )}}
      {{end}}
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Evidence</div>
        <h2>Attachments</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Attachments}}
      <div class="detail-block">
        <div><a href="/api/attachments/{{.AttachmentID}}/content">{{.OriginalFileName}}</a></div>
        <div class="meta">{{.MediaType}} | {{.SizeBytes}} bytes | {{.LinkRole}}</div>
        {{if .LatestDerivedText.Valid}}
        <pre>{{.LatestDerivedText.String}}</pre>
        {{end}}
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No attachments." "body" "Uploaded evidence and derived text will appear here." )}}
      {{end}}
    </div>
  </section>
</div>

<div class="three-up">
  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Execution</div>
        <h2>AI runs</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Runs}}
      <div class="detail-block" id="{{runSectionID .RunID}}">
        <div><strong>{{.AgentRole}}</strong> / {{.CapabilityCode}}</div>
        <div><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></div>
        <p>{{.Summary}}</p>
        <div class="meta">{{.RunID}}</div>
        <div class="meta">
          Started: {{formatTime .StartedAt}}
          {{if .CompletedAt.Valid}} | Completed: {{formatTime .CompletedAt.Time}}{{end}} |
          <a href="/app/review/audit?entity_type=ai.agent_run&amp;entity_id={{.RunID}}">Audit trail</a>
        </div>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No AI runs yet." "body" "Coordinator and specialist run history will appear here after queued processing." )}}
      {{end}}
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Execution</div>
        <h2>AI steps</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Steps}}
      <div class="detail-block" id="{{stepSectionID .StepID}}">
        <strong>#{{.StepIndex}} {{.StepTitle}}</strong>
        <div class="meta">{{.StepType}} | <a href="{{pageSectionHref (runSectionID .RunID)}}">Run {{.RunID}}</a></div>
        <div><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></div>
        <div class="meta">
          Step: {{.StepID}} | Created: {{formatTime .CreatedAt}} |
          <a href="/app/review/audit?entity_type=ai.agent_run_step&amp;entity_id={{.StepID}}">Audit trail</a>
        </div>
        <details>
          <summary>Step payloads</summary>
          <div class="card-stack">
            <div class="detail-block">
              <div class="eyebrow">Input</div>
              <pre>{{prettyJSON .InputPayload}}</pre>
            </div>
            <div class="detail-block">
              <div class="eyebrow">Output</div>
              <pre>{{prettyJSON .OutputPayload}}</pre>
            </div>
          </div>
        </details>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No AI steps yet." "body" "Step-level execution history will appear here when run traces exist." )}}
      {{end}}
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Artifacts</div>
        <h2>Artifacts</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Artifacts}}
      <div class="detail-block">
        <strong>{{.Title}}</strong>
        <div class="meta">{{.ArtifactType}} | {{formatTime .CreatedAt}}</div>
        <pre>{{prettyJSON .Payload}}</pre>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No artifacts yet." "body" "Saved agent artifacts will appear here after processing." )}}
      {{end}}
    </div>
  </section>
</div>

<div class="three-up">
  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Delegation</div>
        <h2>Delegations</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Delegations}}
      <div class="detail-block" id="{{delegationSectionID .DelegationID}}">
        <strong>{{.CapabilityCode}}</strong>
        <div class="meta">Delegation: {{.DelegationID}}</div>
        <div class="meta">Parent run: <a href="{{pageSectionHref (runSectionID .ParentRunID)}}">{{.ParentRunID}}</a></div>
        <div class="meta">Child run: <a href="{{pageSectionHref (runSectionID .ChildRunID)}}">{{.ChildRunID}}</a> | {{.ChildAgentRole}} / {{.ChildCapabilityCode}}</div>
        {{if .RequestedByStepID.Valid}}<div class="meta">Requested by step: <a href="{{pageSectionHref (stepSectionID .RequestedByStepID.String)}}">{{.RequestedByStepID.String}}</a></div>{{end}}
        <div><span class="status-pill {{statusClass .ChildRunStatus}}">{{.ChildRunStatus}}</span></div>
        <p>{{.Reason}}</p>
        <div class="meta">Created: {{formatTime .CreatedAt}} | <a href="/app/review/audit?entity_type=ai.agent_delegation&amp;entity_id={{.DelegationID}}">Audit trail</a></div>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No delegations yet." "body" "Coordinator delegation traces will appear here when specialist routing occurs." )}}
      {{end}}
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Recommendation trace</div>
        <h2>Recommendations</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Recommendations}}
      <div class="detail-block">
        <strong>{{.Summary}}</strong>
        <div><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></div>
        <div class="meta">
          <a href="{{proposalDetailHref .RecommendationID}}">Open exact proposal</a> |
          <a href="/app/review/proposals?recommendation_id={{.RecommendationID}}">Filtered proposal review</a> |
          <a href="/app/review/audit?entity_type=ai.agent_recommendation&amp;entity_id={{.RecommendationID}}">Audit trail</a>
          {{if .ApprovalID.Valid}} | <a href="{{approvalReviewHref .ApprovalID.String}}">Exact approval</a>{{end}}
        </div>
        <pre>{{prettyJSON .Payload}}</pre>
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No recommendations yet." "body" "Recommendation payloads will appear here after the coordinator produces downstream actions." )}}
      {{end}}
    </div>
  </section>

  <section class="panel">
    <div class="section-head">
      <div>
        <div class="eyebrow">Downstream continuity</div>
        <h2>Proposals</h2>
      </div>
    </div>
    <div class="card-stack">
      {{range .Detail.Proposals}}
      <div class="detail-block">
        <strong><a href="{{proposalDetailHref .RecommendationID}}">{{.Summary}}</a></strong>
        <div class="meta">Recommendation: {{.RecommendationStatus}} | Approval: {{.ApprovalStatus.String}}</div>
        <div class="meta">
          Request: <a href="{{inboundRequestReview .RequestReference}}">{{.RequestReference}}</a> |
          Audit: <a href="/app/review/audit?entity_type=ai.agent_recommendation&amp;entity_id={{.RecommendationID}}">proposal trail</a>
        </div>
        <div class="meta">
          Document: {{if .DocumentID.Valid}}<a href="{{documentReviewHref .DocumentID.String}}">{{.DocumentTitle.String}}</a>{{else}}{{.DocumentTitle.String}}{{end}}
          {{if .ApprovalID.Valid}} | Approval: <a href="{{approvalReviewHref .ApprovalID.String}}">{{if .ApprovalQueueCode.Valid}}{{.ApprovalQueueCode.String}}{{else}}approval{{end}}</a>{{end}}
        </div>
        {{if .ApprovalID.Valid}}
        <form method="post" action="/app/approvals/{{.ApprovalID.String}}/decision" class="field-grid compact-form">
          <input type="hidden" name="return_to" value="{{inboundRequestHref $.Detail.Request.RequestReference}}">
          <label>Decision note
            <input type="text" name="decision_note" placeholder="Decision note">
          </label>
          <div class="action-group">
            <button type="submit" name="decision" value="approved">Approve</button>
            <button type="submit" name="decision" value="rejected" class="secondary">Reject</button>
          </div>
        </form>
        {{end}}
      </div>
      {{else}}
      {{template "web_empty_state" (dict "title" "No downstream proposals yet." "body" "Proposal, approval, and document continuity will appear here once recommendation review progresses." )}}
      {{end}}
    </div>
  </section>
</div>
{{end}}
{{template "web_shell_end" .}}
{{end}}

{{define "web_approval_detail"}}
{{template "web_shell_start" .}}
{{with .ApprovalDetail}}
{{template "web_page_header" (dict "eyebrow" "Approval detail" "title" (printf "Approval %s" .Entry.ApprovalID) "body" "Review one exact approval request with direct continuity into the source document, upstream proposal, and audit trail.")}}
<section class="hero-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Primary summary</div>
      <h2>{{.Entry.DocumentTitle}}</h2>
      <p>{{.Entry.QueueCode}} | queue {{.Entry.QueueStatus}} | requested {{formatTime .Entry.RequestedAt}}</p>
    </div>
    <div class="action-group">
      <a href="{{approvalQueueHref .Entry.QueueCode .Entry.QueueStatus}}" class="pill-link">Filtered queue view</a>
      <a href="{{documentReviewHref .Entry.DocumentID}}" class="pill-link secondary">Open document</a>
      <a href="/app/review/audit?entity_type=workflow.approval&amp;entity_id={{.Entry.ApprovalID}}" class="pill-link secondary">Audit trail</a>
    </div>
  </div>
  <div class="inline-links compact-copy">
    {{if .Entry.RequestReference.Valid}}<a href="{{inboundRequestHref .Entry.RequestReference.String}}">{{.Entry.RequestReference.String}}</a>{{end}}
    {{if .Entry.RecommendationID.Valid}}<a href="{{proposalDetailHref .Entry.RecommendationID.String}}">Proposal</a>{{end}}
    {{if .Entry.RunID.Valid}}<a href="{{inboundSectionHref (printf "run:%s" .Entry.RunID.String) (runSectionID .Entry.RunID.String)}}">AI run</a>{{end}}
  </div>
  <div><span class="status-pill {{statusClass .Entry.ApprovalStatus}}">{{.Entry.ApprovalStatus}}</span></div>
</section>

<div class="two-up">
  <section class="panel">
    <div class="section-head"><div><div class="eyebrow">Decision</div><h2>Decision</h2></div></div>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr><th>Queue status</th><td><span class="status-pill {{statusClass .Entry.QueueStatus}}">{{.Entry.QueueStatus}}</span></td></tr>
          <tr><th>Requested by</th><td>{{.Entry.RequestedByUserID}}</td></tr>
          <tr><th>Requested at</th><td>{{formatTime .Entry.RequestedAt}}</td></tr>
          <tr><th>Decided by</th><td>{{if .Entry.DecidedByUserID.Valid}}{{.Entry.DecidedByUserID.String}}{{else}}-{{end}}</td></tr>
          <tr><th>Decided at</th><td>{{if .Entry.DecidedAt.Valid}}{{formatTime .Entry.DecidedAt.Time}}{{else}}-{{end}}</td></tr>
        </tbody>
      </table>
    </div>
    {{if eq .Entry.QueueStatus "pending"}}
    <form method="post" action="/app/approvals/{{.Entry.ApprovalID}}/decision" class="field-grid" style="margin-top:16px;">
      <input type="hidden" name="return_to" value="{{approvalReviewHref .Entry.ApprovalID}}">
      <label>Decision note
        <input type="text" name="decision_note" placeholder="Decision note">
      </label>
      <div class="action-group">
        <button type="submit" name="decision" value="approved">Approve</button>
        <button type="submit" name="decision" value="rejected" class="secondary">Reject</button>
      </div>
    </form>
    {{end}}
  </section>

  <section class="panel">
    <div class="section-head"><div><div class="eyebrow">Linked record</div><h2>Linked record</h2></div></div>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr><th>Document</th><td><a href="{{documentReviewHref .Entry.DocumentID}}">{{.Entry.DocumentTitle}}</a></td></tr>
          <tr><th>Type</th><td>{{.Entry.DocumentTypeCode}}</td></tr>
          <tr><th>Status</th><td><span class="status-pill {{statusClass .Entry.DocumentStatus}}">{{.Entry.DocumentStatus}}</span></td></tr>
          <tr><th>Document number</th><td>{{if .Entry.DocumentNumber.Valid}}{{.Entry.DocumentNumber.String}}{{else}}-{{end}}</td></tr>
          <tr><th>Request</th><td>{{if .Entry.RequestReference.Valid}}<a href="{{inboundRequestHref .Entry.RequestReference.String}}">{{.Entry.RequestReference.String}}</a>{{else}}-{{end}}</td></tr>
          <tr><th>Proposal</th><td>{{if .Entry.RecommendationID.Valid}}<a href="{{proposalDetailHref .Entry.RecommendationID.String}}">{{if .Entry.RecommendationStatus.Valid}}{{.Entry.RecommendationStatus.String}}{{else}}Proposal{{end}}</a>{{else}}-{{end}}</td></tr>
          <tr><th>AI run</th><td>{{if .Entry.RunID.Valid}}<a href="{{inboundSectionHref (printf "run:%s" .Entry.RunID.String) (runSectionID .Entry.RunID.String)}}">{{.Entry.RunID.String}}</a>{{else}}-{{end}}</td></tr>
          <tr><th>Posting</th><td>{{if .Entry.JournalEntryID.Valid}}<a href="{{accountingEntryHref .Entry.JournalEntryID.String}}">Entry #{{.Entry.JournalEntryNumber.Int64}}</a>{{else if .Entry.JournalEntryNumber.Valid}}<a href="/app/review/accounting?document_id={{.Entry.DocumentID}}">Entry #{{.Entry.JournalEntryNumber.Int64}}</a>{{else}}-{{end}}</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</div>
{{end}}
{{template "web_shell_end" .}}
{{end}}

{{define "web_proposal_detail"}}
{{template "web_shell_start" .}}
{{with .ProposalDetail}}
{{template "web_page_header" (dict "eyebrow" "Proposal detail" "title" (printf "Proposal %s" .Review.RecommendationID) "body" "Review one exact coordinator recommendation and continue directly into approval, document, request, and audit context.")}}
<section class="hero-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Primary summary</div>
      <h2>{{.Review.Summary}}</h2>
      <p>Request <a href="/app/inbound-requests/{{.Review.RequestReference}}">{{.Review.RequestReference}}</a> | run {{.Review.RunID}} | created {{formatTime .Review.CreatedAt}}</p>
    </div>
    <div class="action-group">
      <a href="{{proposalReviewHref .Review.RecommendationID .Review.RecommendationStatus .Review.RequestReference}}" class="pill-link">Filtered proposal view</a>
      <a href="/app/review/audit?entity_type=ai.agent_recommendation&amp;entity_id={{.Review.RecommendationID}}" class="pill-link secondary">Audit trail</a>
    </div>
  </div>
  <div><span class="status-pill {{statusClass .Review.RecommendationStatus}}">{{.Review.RecommendationStatus}}</span></div>
</section>

<div class="two-up">
  <section class="panel">
    <div class="section-head"><div><div class="eyebrow">Control chain</div><h2>Control chain</h2></div></div>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr><th>Request</th><td><a href="/app/inbound-requests/{{.Review.RequestReference}}">{{.Review.RequestReference}}</a> | <span class="status-pill {{statusClass .Review.RequestStatus}}">{{.Review.RequestStatus}}</span></td></tr>
          <tr><th>Approval</th><td>{{if .Review.ApprovalID.Valid}}<a href="{{approvalReviewHref .Review.ApprovalID.String}}">{{if .Review.ApprovalQueueCode.Valid}}{{.Review.ApprovalQueueCode.String}}{{else}}approval{{end}}</a>{{if .Review.ApprovalStatus.Valid}} | <span class="status-pill {{statusClass .Review.ApprovalStatus.String}}">{{.Review.ApprovalStatus.String}}</span>{{end}}{{else}}-{{end}}</td></tr>
          <tr><th>Document</th><td>{{if .Review.DocumentID.Valid}}<a href="{{documentReviewHref .Review.DocumentID.String}}">{{.Review.DocumentTitle.String}}</a>{{if .Review.DocumentStatus.Valid}} | <span class="status-pill {{statusClass .Review.DocumentStatus.String}}">{{.Review.DocumentStatus.String}}</span>{{end}}{{else}}-{{end}}</td></tr>
          <tr><th>Suggested queue</th><td>{{if .Review.SuggestedQueueCode.Valid}}{{.Review.SuggestedQueueCode.String}}{{else}}-{{end}}</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel">
    <div class="section-head"><div><div class="eyebrow">Identifiers</div><h2>Identifiers</h2></div></div>
    <div class="table-wrap">
      <table>
        <tbody>
          <tr><th>Recommendation</th><td>{{.Review.RecommendationID}}</td></tr>
          <tr><th>Run</th><td>{{.Review.RunID}}</td></tr>
          <tr><th>Type</th><td>{{.Review.RecommendationType}}</td></tr>
          <tr><th>Document number</th><td>{{if .Review.DocumentNumber.Valid}}{{.Review.DocumentNumber.String}}{{else}}-{{end}}</td></tr>
        </tbody>
      </table>
    </div>
  </section>
</div>

{{if and (not .Review.ApprovalID.Valid) .Review.DocumentID.Valid}}
<section class="panel">
  <div class="section-head">
    <div><div class="eyebrow">Control action</div><h2>Request approval</h2></div>
  </div>
  <form method="post" action="/app/review/proposals/{{.Review.RecommendationID}}/request-approval" class="filter-grid">
    <input type="hidden" name="return_to" value="/app/review/proposals/{{.Review.RecommendationID}}">
    <label>Queue code
      <input type="text" name="queue_code" value="{{.ApprovalQueueCodeDraft}}" placeholder="queue code">
    </label>
    <label>Reason
      <input type="text" name="reason" value="{{.ApprovalReason}}" placeholder="reason">
    </label>
    <div class="filter-actions">
      <button type="submit">Request approval</button>
      <a href="{{documentReviewHref .Review.DocumentID.String}}" class="pill-link secondary">Open document</a>
    </div>
  </form>
</section>
{{end}}
{{end}}
{{template "web_shell_end" .}}
{{end}}

{{define "web_document_detail"}}
{{template "web_shell_start" .}}
{{with .DocumentDetail}}
{{template "web_page_header" (dict "eyebrow" "Document detail" "title" "Document detail" "body" "Review one exact business document with continuity into approval, request, proposal, accounting, and downstream execution or inventory review.")}}
<section class="hero-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Primary summary</div>
      <h2>{{.Review.Title}}</h2>
      <p>{{.Review.DocumentID}}</p>

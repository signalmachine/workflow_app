{{define "web_route_catalog"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Route catalog"
  "title" "Searchable route discovery"
  "body" "Search for a workflow destination, then open the exact route."
)}}

<section class="plain-section">
  <form method="get" action="/app/routes" class="compact-form">
    <label>
      Search query
      <input type="text" name="q" value="{{.RouteCatalog.Query}}" placeholder="requests, approvals, inventory, audit">
    </label>
    <div class="button-row">
      <button type="submit">Search routes</button>
      <a href="/app/routes" class="pill-link secondary">Clear search</a>
    </div>
  </form>
</section>

<section class="plain-section">
  <div class="eyebrow">Results</div>
  {{if .RouteCatalog.Results}}
  <div class="route-list">
    {{range .RouteCatalog.Results}}
    <a class="route-link-card" data-kicker="{{.Category}}" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}</a>
    {{end}}
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No matching routes" "body" "Try a broader workflow term such as requests, approvals, inventory, accounting, or audit." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_admin_access"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Admin access"
  "title" "User and role controls"
  "body" "Use bounded admin-only access maintenance here to provision org memberships and change membership roles on the shared identity foundation."
)}}

<section class="plain-section">
  <div class="eyebrow">Maintenance routes</div>
  <div class="route-list">
    <a class="route-link-card" data-summary="Return to the grouped admin maintenance hub for the broader posture and adjacent privileged setup families." href="/app/admin">Admin hub</a>
    <a class="route-link-card" data-summary="Open approval review when the next step is a governed workflow decision rather than identity maintenance." href="/app/review/approvals?status=pending">Approval queue</a>
    <a class="route-link-card" data-summary="Open audit review when you need the actor and timestamp trail behind a maintenance change." href="/app/review/audit">Audit review</a>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Provision user</div>
      <h2>Attach or create org access</h2>
      <p>Create a new login-backed user for this org, or attach an existing user by email without widening Admin into a broad identity workspace.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/access/users" class="field-grid compact-form">
    <label>Email
      <input type="email" name="email" placeholder="operator@example.com" required>
    </label>
    <label>Display name
      <input type="text" name="display_name" placeholder="Operator One">
    </label>
    <label>Role
      <select name="role_code" required>
        {{range .AdminAccess.RoleOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <label>Password
      <input type="password" name="password" placeholder="Required only for a brand new user">
    </label>
    <div class="button-row">
      <button type="submit">Save access membership</button>
    </div>
  </form>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Current memberships</div>
      <h2>Org-scoped access map</h2>
      <p>Review current users and update membership roles without leaving the promoted admin surface.</p>
    </div>
  </div>

  {{if .AdminAccess.Users}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>User</th>
          <th>Role</th>
          <th>User status</th>
          <th>Membership status</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminAccess.Users}}
        <tr>
          <td><strong>{{.UserDisplayName}}</strong><br>{{.UserEmail}}</td>
          <td>{{.RoleCode}}</td>
          <td>{{.UserStatus}}</td>
          <td>{{.MembershipStatus}}</td>
          <td>
            {{$currentRole := .RoleCode}}
            <form method="post" action="/app/admin/access/users/{{.MembershipID}}/role" class="compact-inline-form">
              <select name="role_code" aria-label="Role for {{.UserEmail}}">
                {{range $.AdminAccess.RoleOptions}}
                <option value="{{.}}" {{if eq . $currentRole}}selected{{end}}>{{.}}</option>
                {{end}}
              </select>
              <button type="submit" class="secondary">Update role</button>
            </form>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No org users yet" "body" "Provision the first org membership from this page to make access continuity explicit." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_admin_inventory"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Admin inventory"
  "title" "Inventory setup maintenance"
  "body" "Use bounded admin-only setup here for inventory items and locations before downstream stock, movement, and reconciliation work depends on them."
)}}

<section class="plain-section">
  <div class="eyebrow">Maintenance routes</div>
  <div class="route-list">
    <a class="route-link-card" data-summary="Return to the grouped admin maintenance hub for the broader posture and adjacent privileged setup families." href="/app/admin">Admin hub</a>
    <a class="route-link-card" data-summary="Open inventory review when the next step is stock, movement, or reconciliation continuity instead of master-data setup." href="/app/review/inventory">Inventory review</a>
    <a class="route-link-card" data-summary="Search the access-scoped route catalog when you need a nearby admin or inventory route." href="/app/routes?q=admin+inventory">Search related routes</a>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inventory items</div>
      <h2>Shared item master</h2>
      <p>Create bounded inventory items on the shared inventory foundation before movement capture or reconciliation depends on them.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/inventory/items" class="field-grid compact-form">
    <label>SKU
      <input type="text" name="sku" placeholder="PUMP-100" required>
    </label>
    <label>Name
      <input type="text" name="name" placeholder="Warehouse pump" required>
    </label>
    <label>Item role
      <select name="item_role" required>
        {{range .AdminInventory.ItemRoleOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <label>Tracking mode
      <select name="tracking_mode" required>
        {{range .AdminInventory.TrackingModeOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <div class="button-row">
      <button type="submit">Create inventory item</button>
    </div>
  </form>

  {{if .AdminInventory.Items}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>SKU</th>
          <th>Name</th>
          <th>Role</th>
          <th>Tracking</th>
          <th>Status</th>
          <th>Control</th>
          <th>Review</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminInventory.Items}}
        <tr>
          <td>{{.SKU}}</td>
          <td>{{.Name}}</td>
          <td>{{.ItemRole}}</td>
          <td>{{.TrackingMode}}</td>
          <td>{{.Status}}</td>
          <td>
            <form method="post" action="/app/admin/inventory/items/{{.ID}}/status" class="compact-inline-form">
              <input type="hidden" name="status" value="{{if eq .Status "active"}}inactive{{else}}active{{end}}">
              <button type="submit" class="secondary">{{if eq .Status "active"}}Mark inactive{{else}}Mark active{{end}}</button>
            </form>
          </td>
          <td><a class="pill-link" href="/app/review/inventory/items/{{.ID}}">Open review</a></td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No inventory items yet" "body" "Create the first item before downstream stock or movement truth depends on it." )}}
  {{end}}
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inventory locations</div>
      <h2>Shared location master</h2>
      <p>Create bounded warehouse, site, van, adjustment, vendor, customer, or installed locations on the same inventory foundation.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/inventory/locations" class="field-grid compact-form">
    <label>Code
      <input type="text" name="code" placeholder="WH-A" required>
    </label>
    <label>Name
      <input type="text" name="name" placeholder="Main warehouse" required>
    </label>
    <label>Location role
      <select name="location_role" required>
        {{range .AdminInventory.LocationRoleOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <div class="button-row">
      <button type="submit">Create inventory location</button>
    </div>
  </form>

  {{if .AdminInventory.Locations}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Role</th>
          <th>Status</th>
          <th>Control</th>
          <th>Review</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminInventory.Locations}}
        <tr>
          <td>{{.Code}}</td>
          <td>{{.Name}}</td>
          <td>{{.LocationRole}}</td>
          <td>{{.Status}}</td>
          <td>
            <form method="post" action="/app/admin/inventory/locations/{{.ID}}/status" class="compact-inline-form">
              <input type="hidden" name="status" value="{{if eq .Status "active"}}inactive{{else}}active{{end}}">
              <button type="submit" class="secondary">{{if eq .Status "active"}}Mark inactive{{else}}Mark active{{end}}</button>
            </form>
          </td>
          <td><a class="pill-link" href="/app/review/inventory/locations/{{.ID}}">Open review</a></td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No inventory locations yet" "body" "Create the first bounded location before stock movement or reconciliation depends on it." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_admin_accounting"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Admin accounting"
  "title" "Accounting setup maintenance"
  "body" "Use bounded admin-only setup forms here for ledger accounts, tax codes, and accounting periods without widening posted-truth review into generic editing."
)}}

<section class="plain-section">
  <div class="eyebrow">Maintenance routes</div>
  <div class="route-list">
    <a class="route-link-card" data-summary="Return to the grouped admin maintenance hub for the broader posture and next queued maintenance families." href="/app/admin">Admin hub</a>
    <a class="route-link-card" data-summary="Use posted-truth accounting review for journals, control accounts, and tax summaries after setup is in place." href="/app/review/accounting">Accounting review</a>
    <a class="route-link-card" data-summary="Search the access-scoped route catalog when the next admin or workflow surface is outside this setup page." href="/app/routes?q=admin+accounting">Search related routes</a>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Ledger accounts</div>
      <h2>Foundational chart setup</h2>
      <p>Create bounded ledger-account records on the shared accounting service seam.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/accounting/ledger-accounts" class="field-grid compact-form">
    <label>Code
      <input type="text" name="code" placeholder="AR1000" required>
    </label>
    <label>Name
      <input type="text" name="name" placeholder="Accounts receivable" required>
    </label>
    <label>Account class
      <select name="account_class" required>
        {{range .AdminAccounting.AccountClassOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <label>Control type
      <select name="control_type">
        {{range .AdminAccounting.ControlTypeOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <label>Tax category code
      <input type="text" name="tax_category_code" placeholder="GST_OUTPUT">
    </label>
    <label>
      <input type="checkbox" name="allows_direct_posting" value="true">
      Allow direct posting
    </label>
    <div class="button-row">
      <button type="submit">Create ledger account</button>
    </div>
  </form>

  {{if .AdminAccounting.LedgerAccounts}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Class</th>
          <th>Control</th>
          <th>Direct posting</th>
          <th>Status</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminAccounting.LedgerAccounts}}
        <tr>
          <td>{{.Code}}</td>
          <td>{{.Name}}</td>
          <td>{{.AccountClass}}</td>
          <td>{{.ControlType}}</td>
          <td>{{if .AllowsDirectPosting}}yes{{else}}no{{end}}</td>
          <td>{{.Status}}</td>
          <td>
            <form method="post" action="/app/admin/accounting/ledger-accounts/{{.ID}}/status" class="compact-inline-form">
              <input type="hidden" name="status" value="{{if eq .Status "active"}}inactive{{else}}active{{end}}">
              <button type="submit" class="secondary">{{if eq .Status "active"}}Mark inactive{{else}}Mark active{{end}}</button>
            </form>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No ledger accounts yet" "body" "Create the first bounded ledger account to seed downstream accounting setup." )}}
  {{end}}
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Tax codes</div>
      <h2>Tax setup</h2>
      <p>Bind GST or TDS codes to the relevant receivable or payable control accounts.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/accounting/tax-codes" class="field-grid compact-form">
    <label>Code
      <input type="text" name="code" placeholder="GST18" required>
    </label>
    <label>Name
      <input type="text" name="name" placeholder="GST 18%" required>
    </label>
    <label>Tax type
      <select name="tax_type" required>
        {{range .AdminAccounting.TaxTypeOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <label>Rate basis points
      <input type="number" name="rate_basis_points" min="0" max="10000" step="1" value="0" required>
    </label>
    <label>Receivable account
      <select name="receivable_account_id">
        <option value="">None</option>
        {{range .AdminAccounting.LedgerAccounts}}
        <option value="{{.ID}}">{{.Code}} - {{.Name}}</option>
        {{end}}
      </select>
    </label>
    <label>Payable account
      <select name="payable_account_id">
        <option value="">None</option>
        {{range .AdminAccounting.LedgerAccounts}}
        <option value="{{.ID}}">{{.Code}} - {{.Name}}</option>
        {{end}}
      </select>
    </label>
    <div class="button-row">
      <button type="submit">Create tax code</button>
    </div>
  </form>

  {{if .AdminAccounting.TaxCodes}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>Type</th>
          <th>Rate</th>
          <th>Status</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminAccounting.TaxCodes}}
        <tr>
          <td>{{.Code}}</td>
          <td>{{.Name}}</td>
          <td>{{.TaxType}}</td>
          <td>{{.RateBasisPoints}}</td>
          <td>{{.Status}}</td>
          <td>
            <form method="post" action="/app/admin/accounting/tax-codes/{{.ID}}/status" class="compact-inline-form">
              <input type="hidden" name="status" value="{{if eq .Status "active"}}inactive{{else}}active{{end}}">
              <button type="submit" class="secondary">{{if eq .Status "active"}}Mark inactive{{else}}Mark active{{end}}</button>
            </form>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No tax codes yet" "body" "Create GST or TDS setup once the matching control accounts exist." )}}
  {{end}}
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Accounting periods</div>
      <h2>Posting-control windows</h2>
      <p>Create bounded accounting periods and close them explicitly when posting should stop for that range.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/accounting/periods" class="field-grid compact-form">
    <label>Period code
      <input type="text" name="period_code" placeholder="FY2026-04" required>
    </label>
    <label>Start on
      <input type="date" name="start_on" required>
    </label>
    <label>End on
      <input type="date" name="end_on" required>
    </label>
    <div class="button-row">
      <button type="submit">Create accounting period</button>
    </div>
  </form>

  {{if .AdminAccounting.AccountingPeriods}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Period</th>
          <th>Start</th>
          <th>End</th>
          <th>Status</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminAccounting.AccountingPeriods}}
        <tr>
          <td>{{.PeriodCode}}</td>
          <td>{{formatTime .StartOn}}</td>
          <td>{{formatTime .EndOn}}</td>
          <td><span class="{{statusClass .Status}}">{{.Status}}</span></td>
          <td>
            {{if eq .Status "open"}}
            <form method="post" action="/app/admin/accounting/periods/{{.ID}}/close">
              <button type="submit" class="secondary">Close period</button>
            </form>
            {{else}}
            Closed
            {{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No accounting periods yet" "body" "Create the first posting window before relying on period-close controls." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_admin_parties"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Admin parties"
  "title" "Customer and party setup"
  "body" "Use bounded admin-only maintenance here for customer and vendor support records on the shared parties model without reviving CRM-first product gravity."
)}}

<section class="plain-section">
  <div class="eyebrow">Maintenance routes</div>
  <div class="route-list">
    <a class="route-link-card" data-summary="Return to the grouped admin maintenance hub for the broader posture and later privileged controls." href="/app/admin">Admin hub</a>
    <a class="route-link-card" data-summary="Open document review when the next step is downstream workflow continuity instead of support-record setup." href="/app/review/documents">Document review</a>
    <a class="route-link-card" data-summary="Search the access-scoped route catalog when you need a nearby setup or review route." href="/app/routes?q=admin+party">Search related routes</a>
  </div>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Create party</div>
      <h2>Bounded counterparty setup</h2>
      <p>Create customer, vendor, hybrid, or other support records on the shared parties service seam.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/parties" class="field-grid compact-form">
    <label>Party code
      <input type="text" name="party_code" placeholder="CUST-100" required>
    </label>
    <label>Display name
      <input type="text" name="display_name" placeholder="Northwind Service" required>
    </label>
    <label>Legal name
      <input type="text" name="legal_name" placeholder="Northwind Service Pvt Ltd">
    </label>
    <label>Party kind
      <select name="party_kind" required>
        {{range .AdminParties.PartyKindOptions}}
        <option value="{{.}}">{{.}}</option>
        {{end}}
      </select>
    </label>
    <div class="button-row">
      <button type="submit">Create party</button>
    </div>
  </form>
</section>

<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Existing parties</div>
      <h2>Customer and vendor support records</h2>
      <p>Open exact detail to confirm kind, status, and contact continuity before downstream document work depends on the record.</p>
    </div>
  </div>

  {{if .AdminParties.Parties}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Code</th>
          <th>Display name</th>
          <th>Kind</th>
          <th>Status</th>
          <th>Control</th>
          <th>Detail</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminParties.Parties}}
        <tr>
          <td>{{.PartyCode}}</td>
          <td>{{.DisplayName}}</td>
          <td>{{.PartyKind}}</td>
          <td>{{.Status}}</td>
          <td>
            <form method="post" action="/app/admin/parties/{{.ID}}/status" class="compact-inline-form">
              <input type="hidden" name="status" value="{{if eq .Status "active"}}inactive{{else}}active{{end}}">
              <button type="submit" class="secondary">{{if eq .Status "active"}}Mark inactive{{else}}Mark active{{end}}</button>
            </form>
          </td>
          <td><a class="pill-link" href="/app/admin/parties/{{.ID}}">Open detail</a></td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No parties yet" "body" "Create the first customer or vendor support record before downstream document ownership depends on it." )}}
  {{end}}
</section>

{{if .AdminParties.Detail}}
<section class="panel">
  <div class="section-head">
    <div>
      <div class="eyebrow">Exact detail</div>
      <h2>{{.AdminParties.Detail.Party.DisplayName}}</h2>
      <p>Use exact detail to confirm the shared party identity and current contact visibility before routing into workflow work.</p>
    </div>
  </div>

  <div class="detail-grid">
    <div><strong>Party code</strong><br>{{.AdminParties.Detail.Party.PartyCode}}</div>
    <div><strong>Kind</strong><br>{{.AdminParties.Detail.Party.PartyKind}}</div>
    <div><strong>Status</strong><br>{{.AdminParties.Detail.Party.Status}}</div>
    <div><strong>Legal name</strong><br>{{if .AdminParties.Detail.Party.LegalName}}{{.AdminParties.Detail.Party.LegalName}}{{else}}-{{end}}</div>
  </div>

  <div class="button-row">
    <form method="post" action="/app/admin/parties/{{.AdminParties.Detail.Party.ID}}/status" class="compact-inline-form">
      <input type="hidden" name="status" value="{{if eq .AdminParties.Detail.Party.Status "active"}}inactive{{else}}active{{end}}">
      <button type="submit" class="secondary">{{if eq .AdminParties.Detail.Party.Status "active"}}Mark party inactive{{else}}Mark party active{{end}}</button>
    </form>
  </div>

  <div class="section-head">
    <div>
      <div class="eyebrow">Contacts</div>
      <h3>Visible support contacts</h3>
      <p>Add the bounded contact records that downstream document, approval, and execution flows may need to reuse.</p>
    </div>
  </div>

  <form method="post" action="/app/admin/parties/{{.AdminParties.Detail.Party.ID}}/contacts" class="stack-form">
    <div class="form-grid">
      <label>Full name
        <input type="text" name="full_name" required>
      </label>
      <label>Role title
        <input type="text" name="role_title">
      </label>
      <label>Email
        <input type="email" name="email">
      </label>
      <label>Phone
        <input type="text" name="phone">
      </label>
    </div>
    <label class="checkbox-field">
      <input type="checkbox" name="is_primary" value="true">
      Mark as primary contact
    </label>
    <p class="help-text">Provide at least one direct contact method so operators can reuse this support record downstream.</p>
    <div class="button-row">
      <button type="submit">Create contact</button>
    </div>
  </form>

  {{if .AdminParties.Detail.Contacts}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Role</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Primary</th>
        </tr>
      </thead>
      <tbody>
        {{range .AdminParties.Detail.Contacts}}
        <tr>
          <td>{{.FullName}}</td>
          <td>{{if .RoleTitle}}{{.RoleTitle}}{{else}}-{{end}}</td>
          <td>{{if .Email.Valid}}{{.Email.String}}{{else}}-{{end}}</td>
          <td>{{if .Phone.Valid}}{{.Phone.String}}{{else}}-{{end}}</td>
          <td>{{if .IsPrimary}}yes{{else}}no{{end}}</td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No contacts for this party" "body" "Create the first shared support contact here before downstream document or execution work depends on it." )}}
  {{end}}
</section>
{{end}}

{{template "web_shell_end" .}}
{{end}}

{{define "web_settings"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Settings"
  "title" "User-scoped settings and continuity"

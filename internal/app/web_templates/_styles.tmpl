{{define "web_styles"}}
:root {
  --bg: #edf1f6;
  --surface: #f8fafc;
  --surface-muted: #f1f5f9;
  --surface-strong: #dbe4ef;
  --ink: #121926;
  --ink-soft: #526072;
  --line: #cfd8e3;
  --line-strong: #a8b5c5;
  --accent: #315b8d;
  --accent-strong: #203a59;
  --accent-soft: #e5edf7;
  --good: #156f52;
  --bad: #b23b4f;
  --neutral: #51657b;
  --shadow: 0 10px 24px rgba(15, 23, 42, 0.06);
  --radius-xl: 18px;
  --radius-lg: 14px;
  --radius-md: 10px;
  --radius-sm: 999px;
  --max-width: 1320px;
  --font-sans: "IBM Plex Sans", "Segoe UI", sans-serif;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: linear-gradient(180deg, #eef3f8 0%, #e9eef5 100%); color: var(--ink); font-family: var(--font-sans); }
body { min-height: 100vh; }
a { color: var(--accent-strong); text-decoration: none; }
a:hover { text-decoration: underline; }

.pill-link,
.button-link,
button,
input[type="submit"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  background: var(--accent);
  color: #fff;
  font: inherit;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
}

.pill-link.secondary,
.button-link.secondary,
button.secondary,
input[type="submit"].secondary {
  background: #fff;
  color: var(--accent-strong);
  border-color: var(--line);
}

.button-row,
.action-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.flash-stack {
  display: grid;
  gap: 12px;
}

.flash {
  padding: 12px 14px;
  border-radius: var(--radius-md);
  border: 1px solid var(--line);
  background: #fff;
}

.flash.notice {
  border-color: #b7d0ff;
  background: #eef5ff;
}

.flash.error {
  border-color: #efb4bc;
  background: #fff1f3;
}

.public-shell {
  width: min(720px, calc(100vw - 32px));
  margin: 0 auto;
  padding: 24px 0 40px;
}

.shell-frame {
  width: min(var(--max-width), calc(100vw - 32px));
  margin: 0 auto;
  padding: 18px 0 32px;
  display: grid;
  gap: 16px;
}

.shell-header {
  display: grid;
  gap: 10px;
}

.session-meta,
.panel-subtitle,
.meta,
.eyebrow,
.section-copy {
  color: var(--ink-soft);
}

.shell-topbar,
.public-topbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  min-height: 60px;
  padding: 10px 14px;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: rgba(248, 250, 252, 0.94);
  box-shadow: var(--shadow);
}

.brand-link {
  display: inline-flex;
  align-items: center;
  gap: 12px;
  color: var(--ink);
  text-decoration: none;
}

.brand-link:hover {
  text-decoration: none;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 12px;
  background: var(--accent-soft);
  border: 1px solid #c7d5e7;
  color: var(--accent-strong);
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.brand-copy {
  display: grid;
  gap: 2px;
}

.brand-copy strong {
  font-size: 1rem;
  line-height: 1.1;
}

.brand-copy span {
  color: var(--ink-soft);
  font-size: 0.86rem;
}

.session-tools {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-end;
  gap: 10px;
}

.session-pill {
  display: grid;
  gap: 2px;
  padding: 8px 12px;
  border-radius: 12px;
  background: var(--surface-muted);
  border: 1px solid var(--line);
  line-height: 1.25;
}

.session-pill span {
  color: var(--ink-soft);
  font-size: 0.84rem;
}

.shell-nav,
.panel,
.table-card,
.summary-card,
.detail-block,
.feed-item,
.result-card {
  background: rgba(248, 250, 252, 0.96);
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow);
}

.shell-nav {
  padding: 10px 12px;
}

.shell-nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 8px 14px;
}

.nav-band {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 10px 14px;
}

.nav-band-label {
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #617489;
}

.nav-bubbles {
  display: flex;
  flex-wrap: wrap;
  gap: 8px 10px;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  min-height: 36px;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  color: var(--accent-strong);
  text-decoration: none;
  background: #fff;
  border: 1px solid var(--line);
  font-weight: 600;
  font-size: 0.92rem;
}

.nav-link:hover,
.nav-link.is-active {
  background: var(--accent-soft);
  border-color: #aac1db;
  color: var(--accent-strong);
  text-decoration: none;
}

.utility-menu summary {
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 36px;
  padding: 0 14px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--line);
  background: #fff;
  font-weight: 600;
}

.utility-menu summary::-webkit-details-marker {
  display: none;
}

.utility-menu[open] summary {
  background: var(--accent-soft);
  border-color: #aac1db;
}

.utility-menu-panel {
  display: grid;
  gap: 12px;
  margin-top: 12px;
  padding: 12px 0 0;
  border-top: 1px solid var(--line);
}

.shell-main {
  display: grid;
  gap: 16px;
}

.page-stack {
  display: grid;
  gap: 16px;
}

.page-header,
.panel,
.result-card,
.feed-item,
.table-card {
  padding: 18px 20px;
}

.page-header {
  display: grid;
  gap: 8px;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.eyebrow {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.page-header h1,
.hero-card h2,
.panel h2,
.panel h3,
.table-card h2,
.table-card h3,
.summary-card h3,
.result-card h2 {
  margin: 0;
}

.page-header p,
.panel p,
.table-card p,
.result-card p {
  margin: 0;
  line-height: 1.5;
}

.two-up,
.three-up,
.status-grid {
  display: grid;
  gap: 14px;
}

.two-up {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-up {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.status-grid {
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
}

.summary-card,
.detail-block {
  padding: 14px 16px;
}

.summary-card .count {
  font-size: 1.5rem;
  font-weight: 700;
}

.summary-card .meta,
.detail-block .meta {
  margin-top: 8px;
}

.result-card {
  background: rgba(248, 250, 252, 0.98);
}

.table-card {
  display: grid;
  gap: 12px;
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: 12px;
  background: #fff;
}

table {
  width: 100%;
  border-collapse: collapse;
}

.table-wrap > table {
  min-width: 640px;
}

th,
td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: top;
}

th {
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--ink-soft);
  background: #f4f7fb;
}

tr:last-child td { border-bottom: 0; }

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: var(--radius-sm);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background: #edf3fb;
  color: var(--neutral);
}

.status-good { background: #e8f5ee; color: var(--good); }
.status-bad { background: #fff0f1; color: var(--bad); }
.status-neutral { background: #edf3fb; color: var(--neutral); }

.field-grid {
  display: grid;
  gap: 14px;
}

.filter-grid {
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  align-items: end;
}

.filter-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.field-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

label {
  display: grid;
  gap: 8px;
  font-weight: 600;
}

input[type="text"],
input[type="email"],
input[type="password"],
input[type="date"],
textarea,
select,
input[type="file"] {
  width: 100%;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: #fff;
  color: var(--ink);
  font: inherit;
}

textarea { min-height: 180px; resize: vertical; }

.feed-list,
.card-stack,
.detail-grid,
.review-link-list,
.catalog-grid,
.directory-list,
.route-list,
.metric-list,
.summary-strip,
.surface-stack {
  display: grid;
  gap: 12px;
}

.catalog-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.summary-strip {
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
}

.directory-list a {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  padding: 11px 12px;
  border-radius: 10px;
  border: 1px solid var(--line);
  background: #fff;
  font-weight: 600;
}

.directory-list a::after {
  content: "Open";
  color: var(--ink-soft);
  font-size: 0.82rem;
  font-weight: 500;
}

.directory-list a:hover {
  text-decoration: none;
  background: var(--accent-soft);
}

.plain-section {
  display: grid;
  gap: 10px;
  padding: 0;
  background: transparent;
  border: 0;
  box-shadow: none;
}

.plain-section h2,
.plain-section p,
.plain-section ul {
  margin: 0;
}

.route-list,
.metric-list {
  gap: 8px;
}

.route-list a,
.metric-link {
  display: inline-flex;
  align-items: baseline;
  gap: 8px;
  width: fit-content;
  max-width: 100%;
  padding: 3px 0;
  color: var(--accent-strong);
  font-weight: 600;
}

.route-list a:hover,
.metric-link:hover {
  text-decoration: underline;
}

.metric-label {
  color: var(--ink);
}

.metric-value {
  color: var(--ink-soft);
  font-size: 0.92rem;
  font-weight: 500;
}

.surface-stack {
  grid-template-columns: minmax(0, 1fr);
}

.page-actions,
.compact-form {
  display: grid;
  gap: 12px;
}

.detail-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.feed-item {
  display: grid;
  gap: 12px;
}

.feed-head {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: space-between;
  align-items: baseline;
}

.empty-state {
  padding: 16px;
  border-radius: 12px;
  border: 1px dashed var(--line-strong);
  background: #f6f8fb;
}

.empty-state h3 {
  margin: 0 0 8px;
}

.section-stack {
  display: grid;
  gap: 18px;
}

.section-head {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12px;
  align-items: start;
}

.section-head h2,
.section-head p {
  margin: 0;
}

pre {
  margin: 0;
  padding: 16px;
  border-radius: var(--radius-lg);
  background: #f5f6ee;
  border: 1px solid var(--line);
  overflow-x: auto;
  font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
  font-size: 0.9rem;
  line-height: 1.55;
}

details {
  display: grid;
  gap: 12px;
}

summary {
  cursor: pointer;
  font-weight: 600;
}

.inline-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 14px;
}

.compact-copy {
  font-size: 0.95rem;
}

.login-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr);
  gap: 14px;
  align-items: start;
}

.login-panel {
  padding: 24px;
}

.login-shell {
  min-height: 100vh;
}

.login-shell .public-shell {
  padding-top: 40px;
}

.compact-intro {
  display: grid;
  gap: 10px;
  padding: 16px 18px;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  background: rgba(248, 250, 252, 0.92);
}

.compact-intro h2,
.compact-intro p {
  margin: 0;
}

.workflow-page {
  display: grid;
  gap: 16px;
}

.workflow-page .panel,
.workflow-page .table-card,
.workflow-page .result-card {
  width: 100%;
}

@media (max-width: 1080px) {
  .three-up,
  .two-up,
  .login-grid,
  .field-grid.two {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .public-shell,
  .shell-frame {
    width: min(100vw - 20px, var(--max-width));
  }

  .shell-nav,
  .page-header,
  .panel,
  .table-card,
  .result-card,
  .feed-item,
  .summary-card,
  .detail-block {
    padding: 18px;
  }

  th,
  td {
    padding: 12px;
  }

  .nav-bubbles {
    gap: 8px;
  }

  .nav-link,
  .utility-menu summary {
    width: 100%;
    justify-content: center;
  }

  .shell-topbar,
  .public-topbar,
  .shell-nav,
  .nav-band,
  .session-tools {
    align-items: stretch;
  }
}
{{end}}

package pages

import "accounting-agent/web/templates/layouts"

templ SettingsModulePage(d layouts.AppLayoutData, title, subtitle string) {
	@layouts.AppLayout(d) {
		<div class="max-w-5xl space-y-6">
			<div>
				<h1 class="text-2xl font-bold text-slate-900">{ title }</h1>
				<p class="text-sm text-slate-500 mt-0.5">{ subtitle }</p>
			</div>

			<div class="bg-white rounded-xl border border-gray-200 p-6 space-y-4">
				<p class="text-sm text-slate-600">
					This settings area is now available as a dedicated page and will be expanded with full controls in upcoming phases.
				</p>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
					<a href="/settings" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 text-sm text-slate-700 hover:bg-gray-50 transition-colors">
						<span>←</span>
						<span>Back to Settings Home</span>
					</a>
					<a href="/about" class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-200 text-sm text-slate-700 hover:bg-gray-50 transition-colors">
						<span>ℹ️</span>
						<span>Application Overview</span>
					</a>
				</div>
			</div>
		</div>
	}
}

        "value" .ProposalCount
        "body" (printf "%d requests / %d documents" .RequestCount .DocumentCount)
        "action_href" (proposalReviewHref "" .RecommendationStatus "")
        "action_label" (printf "Open %s" .RecommendationStatus)
      )}}
    {{end}}
  {{else}}
    {{template "web_empty_state" (dict "title" "No proposal summary available." "body" "Processed proposal status totals will appear here when the coordinator has downstream review material." )}}
  {{end}}
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Processed proposals</div>
      <h2>Keep downstream approval and document continuity visible</h2>
    </div>
  </div>
  {{if .Proposals.ProcessedProposals}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Request</th>
          <th>Proposal</th>
          <th>Status</th>
          <th>Summary</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Proposals.ProcessedProposals}}
        <tr>
          <td><a href="{{inboundRequestHref .RequestReference}}">{{.RequestReference}}</a></td>
          <td><a href="{{proposalDetailHref .RecommendationID}}">{{.RecommendationID}}</a></td>
          <td><span class="status-pill {{statusClass .RecommendationStatus}}">{{.RecommendationStatus}}</span></td>
          <td>{{.Summary}}</td>
          <td class="inline-links">
            <a href="{{proposalDetailHref .RecommendationID}}">Open exact proposal</a>
            {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">Open exact approval</a>{{end}}
            {{if and .ApprovalQueueCode.Valid .ApprovalStatus.Valid}}<a href="{{approvalQueueHref .ApprovalQueueCode.String .ApprovalStatus.String}}">{{.ApprovalQueueCode.String}}</a>{{end}}
            {{if .DocumentID.Valid}}<a href="{{documentReviewHref .DocumentID.String}}">Open document</a>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No proposals match the current filters." "body" "Process queued intake or clear the filters to repopulate the workbench." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_documents"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Document review"
  "body" "Scan downstream business documents with just enough upstream request, proposal, approval, and accounting continuity."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Browse exact documents or narrow one type and status</h2>
    </div>
  </div>
  <form method="get" action="/app/review/documents" class="filter-grid">
    <label>
      Document ID
      <input type="text" name="document_id" value="{{.Documents.DocumentID}}" placeholder="doc-123">
    </label>
    <label>
      Type code
      <input type="text" name="type_code" value="{{.Documents.TypeCode}}" placeholder="invoice">
    </label>
    <label>
      Status
      <input type="text" name="status" value="{{.Documents.Status}}" placeholder="submitted, posted">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/documents" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Documents</div>
      <h2>Downstream records stay tied to their workflow origin</h2>
    </div>
  </div>
  {{if .Documents.Documents}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Document</th>
          <th>Type</th>
          <th>Status</th>
          <th>Created</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Documents.Documents}}
        <tr>
          <td><a href="{{documentReviewHref .DocumentID}}">{{.Title}}</a></td>
          <td>{{.TypeCode}}{{if .NumberValue.Valid}}<div class="meta">{{.NumberValue.String}}</div>{{end}}</td>
          <td><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></td>
          <td>{{formatTime .CreatedAt}}</td>
          <td class="inline-links">
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            {{if .RecommendationID.Valid}}<a href="{{proposalDetailHref .RecommendationID.String}}">Proposal</a>{{end}}
            {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">{{if .ApprovalQueueCode.Valid}}{{.ApprovalQueueCode.String}}{{else}}Approval{{end}}</a>{{end}}
            <a href="/app/review/audit?entity_type=documents.document&amp;entity_id={{.DocumentID}}">Audit trail</a>
            <a href="{{workOrderReviewHref "" "" .DocumentID}}">Work-order review</a>
            {{if .JournalEntryID.Valid}}<a href="{{accountingEntryHref .JournalEntryID.String}}">Entry #{{.JournalEntryNumber.Int64}}</a>{{else if .DocumentID}}<a href="{{accountingReviewHref "" "" "" "" .DocumentID "" "" "" "" ""}}">Accounting review</a>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No documents match the current filters." "body" "Documents will appear here once proposal approval or posting creates downstream business records." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_accounting"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Accounting review"
  "body" "Keep journal entries, control balances, and tax summaries on one shared review surface without reopening the detail pages yet."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Use one filter seam across entries, balances, and tax summaries</h2>
    </div>
  </div>
  <form method="get" action="/app/review/accounting" class="filter-grid">
    <label>
      Entry ID
      <input type="text" name="entry_id" value="{{.Accounting.EntryID}}" placeholder="entry-123">
    </label>
    <label>
      Document ID
      <input type="text" name="document_id" value="{{.Accounting.DocumentID}}" placeholder="doc-123">
    </label>
    <label>
      Start on
      <input type="date" name="start_on" value="{{.Accounting.StartOn}}">
    </label>
    <label>
      End on
      <input type="date" name="end_on" value="{{.Accounting.EndOn}}">
    </label>
    <label>
      As of
      <input type="date" name="as_of" value="{{.Accounting.AsOf}}">
    </label>
    <label>
      Tax code
      <input type="text" name="tax_code" value="{{.Accounting.TaxCode}}" placeholder="gst_output">
    </label>
    <label>
      Tax type
      <input type="text" name="tax_type" value="{{.Accounting.TaxType}}" placeholder="gst">
    </label>
    <label>
      Control type
      <input type="text" name="control_type" value="{{.Accounting.ControlType}}" placeholder="gst_receivable">
    </label>
    <label>
      Account ID
      <input type="text" name="account_id" value="{{.Accounting.AccountID}}" placeholder="account-123">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/accounting" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<div class="three-up">
  {{template "web_summary_card" (dict "label" "Journal entries" "value" (len .Accounting.JournalEntries) "body" "Current filtered posting rows" )}}
  {{template "web_summary_card" (dict "label" "Control balances" "value" (len .Accounting.ControlBalances) "body" "Current filtered control accounts" )}}
  {{template "web_summary_card" (dict "label" "Tax summaries" "value" (len .Accounting.TaxSummaries) "body" "Current filtered tax summaries" )}}
</div>

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Quick pivots</div>
      <h2>Tax and control links</h2>
    </div>
  </div>
  <div class="inline-links">
    {{range .Accounting.TaxSummaries}}
      <a href="{{accountingReviewHref "" "" "" "" "" .TaxType .TaxCode "" "" "tax-summaries"}}">{{.TaxCode}}</a>
      <a href="{{taxSummaryHref .TaxCode}}">Tax detail</a>
    {{end}}
    {{range .Accounting.ControlBalances}}
      <a href="{{controlAccountHref .AccountID}}">{{.AccountCode}}</a>
      <a href="{{accountingReviewHref "" "" "" "" "" "" "" .ControlType "" ""}}">{{.ControlType}}</a>
    {{end}}
  </div>
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Journal review</div>
      <h2>Entries</h2>
    </div>
  </div>
  {{if .Accounting.JournalEntries}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Entry</th>
          <th>Kind</th>
          <th>Posted</th>
          <th>Amounts</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Accounting.JournalEntries}}
        <tr>
          <td><a href="{{accountingEntryHref .EntryID}}">Entry #{{.EntryNumber}}</a><div class="meta">{{.Summary}}</div></td>
          <td>{{.EntryKind}}<div class="meta">{{.CurrencyCode}} / {{.TaxScopeCode}}</div></td>
          <td>{{formatTime .PostedAt}}</td>
          <td>{{.TotalDebitMinor}} / {{.TotalCreditMinor}}</td>
          <td class="inline-links">
            {{if .SourceDocumentID.Valid}}<a href="{{documentReviewHref .SourceDocumentID.String}}">Document</a>{{end}}
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            {{if .RecommendationID.Valid}}<a href="{{proposalDetailHref .RecommendationID.String}}">Proposal</a>{{end}}
            {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">{{if .ApprovalQueueCode.Valid}}{{.ApprovalQueueCode.String}}{{else}}Approval{{end}}</a>{{end}}
            {{if .SourceDocumentID.Valid}}<a href="/app/review/audit?entity_type=documents.document&amp;entity_id={{.SourceDocumentID.String}}">Document audit</a>{{end}}
            <a href="/app/review/audit?entity_type=accounting.journal_entry&amp;entity_id={{.EntryID}}">Entry audit</a>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No journal entries match the current filters." "body" "Posting rows will appear here as accounting review data accumulates." )}}
  {{end}}
</section>

<div class="two-up">
  <section class="table-card">
    <div class="section-head">
      <div>
        <div class="eyebrow">Control accounts</div>
        <h2>Balances</h2>
      </div>
    </div>
    {{if .Accounting.ControlBalances}}

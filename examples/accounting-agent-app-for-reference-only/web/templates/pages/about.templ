package pages

import "accounting-agent/web/templates/layouts"

templ About(d layouts.AppLayoutData) {
	@layouts.AppLayout(d) {
		<div class="max-w-2xl mx-auto py-12 px-4">
			<!-- Logo / icon block -->
			<div class="flex items-center gap-4 mb-8">
				<div class="w-14 h-14 rounded-2xl bg-slate-900 flex items-center justify-center text-2xl flex-shrink-0">
					⌂
				</div>
				<div>
					<h1 class="text-2xl font-bold text-slate-800">Accounting</h1>
					<p class="text-sm text-slate-500">AI-powered double-entry accounting</p>
				</div>
			</div>
			<!-- About card -->
			<div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8 mb-6">
				<h2 class="text-base font-semibold text-slate-700 mb-3">About this application</h2>
				<p class="text-sm text-slate-600 leading-relaxed mb-4">
					This is an AI-powered accounting application built by <span class="font-medium text-slate-800">Vinod Mathew</span>.
					It combines a modern double-entry ledger engine modelled after SAP&apos;s architecture with a
					GPT-4o AI agent that converts natural language into journal entries, validated and committed
					with full double-entry precision.
				</p>
				<p class="text-sm text-slate-600 leading-relaxed">
					The system covers the full procure-to-pay and order-to-cash cycles — sales orders, purchase orders,
					goods receipt, inventory, vendor invoicing, and financial reporting — all accessible through a clean web UI and an interactive AI chat.
				</p>
			</div>
			<!-- Coming soon card -->
			<div class="bg-blue-50 border border-blue-200 rounded-2xl p-8">
				<div class="flex items-center gap-2 mb-3">
					<span class="text-base">🇮🇳</span>
					<h2 class="text-base font-semibold text-slate-700">Coming soon — Indian Tax Compliance</h2>
				</div>
				<p class="text-sm text-slate-600 leading-relaxed mb-3">
					Support for Indian taxation is on the roadmap and will be added in a future release:
				</p>
				<ul class="space-y-2 text-sm text-slate-700">
					<li class="flex items-start gap-2">
						<span class="mt-0.5 text-blue-500">•</span>
						<span><span class="font-medium">GST</span> — Goods and Services Tax (CGST, SGST, IGST) with GSTR-1, GSTR-3B export</span>
					</li>
					<li class="flex items-start gap-2">
						<span class="mt-0.5 text-blue-500">•</span>
						<span><span class="font-medium">TDS</span> — Tax Deducted at Source with automatic TDS computation on vendor payments</span>
					</li>
					<li class="flex items-start gap-2">
						<span class="mt-0.5 text-blue-500">•</span>
						<span><span class="font-medium">TCS</span> — Tax Collected at Source on eligible sales transactions</span>
					</li>
				</ul>
			</div>
		</div>
	}
}

{{define "web_dashboard"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Home"
  "title" .Dashboard.RoleHeadline
  "body" .Dashboard.RoleBody
)}}

<section class="plain-section">
  <div class="eyebrow">Recommended next steps</div>
  <div class="route-list">
    {{range .Dashboard.PrimaryActions}}
    <a class="route-link-card" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}{{if .Badge}} ({{.Badge}}){{end}}</a>
    {{end}}
  </div>
</section>

{{if .Dashboard.SecondaryActions}}
<section class="plain-section">
  <div class="eyebrow">Route directory</div>
  <div class="route-list">
    {{range .Dashboard.SecondaryActions}}
    <a class="route-link-card" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}{{if .Badge}} ({{.Badge}}){{end}}</a>
    {{end}}
  </div>
</section>
{{end}}

<section class="plain-section">
  <div class="eyebrow">Workflow links</div>
  <div class="route-list">
    <a class="route-link-card" data-summary="Open the exact intake queue when the next operator step is claim, review, or troubleshooting." href="/app/review/inbound-requests?status=queued">Queued requests</a>
    <a class="route-link-card" data-summary="Keep explicit decision work close to home when approvals are the highest-leverage unblocker." href="/app/review/approvals?status=pending">Pending approvals</a>
    <a class="route-link-card" data-summary="Continue from processed coordinator output into approval and downstream document continuity." href="/app/review/proposals">Recent proposals</a>
    <a class="route-link-card" data-summary="Search by workflow term or operator intent when grouped navigation is not specific enough." href="/app/routes">Route catalog</a>
  </div>
  <form method="post" action="/app/agent/process-next-queued-inbound-request" class="page-actions">
    <div class="button-row">
      <button type="submit">Process next queued request</button>
    </div>
  </form>
</section>

{{if .Dashboard.InboundSummary}}
<section class="plain-section">
  <div class="eyebrow">Status entry points</div>
  <div class="metric-list">
    {{range .Dashboard.InboundSummary}}
    <a class="metric-link" data-value="{{.RequestCount}}" href="{{inboundRequestsHref .Status ""}}">{{dashboardStatusAction .Status}}</a>
    <p class="meta">{{dashboardStatusBlurb .Status}}</p>
    {{end}}
  </div>
</section>
{{end}}

{{if .Dashboard.InboundRequests}}
<section class="plain-section">
  <div class="eyebrow">Recent requests</div>
  <div class="route-list">
    {{range .Dashboard.InboundRequests}}
    <a href="{{inboundRequestHref .RequestReference}}">{{.RequestReference}} - {{dashboardRequestAction .Status}}</a>
    {{if .FailureReason}}<p class="meta">{{.FailureReason}}</p>{{else if .CancellationReason}}<p class="meta">{{.CancellationReason}}</p>{{end}}
    {{if .LastRunID.Valid}}<a href="{{inboundSectionHref (print "run:" .LastRunID.String) (runSectionID .LastRunID.String)}}">Open latest run</a>{{end}}
    {{end}}
  </div>
</section>
{{end}}

{{if .Dashboard.Approvals}}
<section class="plain-section">
  <div class="eyebrow">Pending approvals</div>
  <div class="route-list">
    {{range .Dashboard.Approvals}}
    <a href="{{approvalReviewHref .ApprovalID}}">{{.QueueCode}}</a>
    <a href="{{approvalQueueHref .QueueCode "pending"}}">{{.QueueCode}}</a>
    <a href="{{approvalReviewHref .ApprovalID}}">Open exact approval</a>
    <a href="/app/review/audit?entity_type=documents.document&amp;entity_id={{.DocumentID}}">Audit trail</a>
    {{end}}
  </div>
</section>
{{end}}

{{if .Dashboard.Proposals}}
<section class="plain-section">
  <div class="eyebrow">Recent proposals</div>
  <div class="route-list">
    {{range .Dashboard.Proposals}}
    <a href="{{proposalDetailHref .RecommendationID}}">Open exact proposal</a>
    {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">Open exact approval</a>{{end}}
    {{if .DocumentID.Valid}}<a href="/app/review/audit?entity_type=documents.document&amp;entity_id={{.DocumentID.String}}">Audit trail</a>{{end}}
    {{end}}
  </div>
</section>
{{end}}

{{template "web_shell_end" .}}
{{end}}

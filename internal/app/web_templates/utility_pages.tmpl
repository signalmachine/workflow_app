{{define "web_route_catalog"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Route catalog"
  "title" "Searchable route discovery"
  "body" "Search for a workflow destination, then open the exact route."
)}}

<section class="plain-section">
  <form method="get" action="/app/routes" class="compact-form">
    <label>
      Search query
      <input type="text" name="q" value="{{.RouteCatalog.Query}}" placeholder="requests, approvals, inventory, audit">
    </label>
    <div class="button-row">
      <button type="submit">Search routes</button>
      <a href="/app/routes" class="pill-link secondary">Clear search</a>
    </div>
  </form>
</section>

<section class="plain-section">
  <div class="eyebrow">Results</div>
  {{if .RouteCatalog.Results}}
  <div class="route-list">
    {{range .RouteCatalog.Results}}
    <a class="route-link-card" data-kicker="{{.Category}}" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}</a>
    {{end}}
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No matching routes" "body" "Try a broader workflow term such as requests, approvals, inventory, accounting, or audit." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_settings"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Settings"
  "title" "User utility surface"
  "body" "Keep utility routes separate from workflow review and activity pages."
)}}

<section class="plain-section">
  <div class="eyebrow">Current session</div>
  <p>{{.Settings.Session.UserDisplayName}}. {{.Settings.Session.UserEmail}} in {{.Settings.Session.OrgName}} as {{.Settings.Session.RoleCode}}.</p>
</section>

<section class="plain-section">
  <div class="eyebrow">Current recommended routes</div>
  <div class="route-list">
    {{range .Settings.PrimaryActions}}
    <a class="route-link-card" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}{{if .Badge}} ({{.Badge}}){{end}}</a>
    {{end}}
  </div>
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_admin"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Admin"
  "title" "Privileged utility surface"
  "body" "Use this page as a simple directory for governance-oriented review routes."
)}}

<section class="plain-section">
  <div class="eyebrow">Admin routes</div>
  <div class="route-list">
    {{range .Admin.AdminActions}}
    <a class="route-link-card" data-summary="{{.Summary}}" href="{{.Href}}">{{.Title}}</a>
    {{end}}
  </div>
</section>

{{template "web_shell_end" .}}
{{end}}

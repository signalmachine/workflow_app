# Primary application database used by the migration runner and future app services.
DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:5432/workflow_app?sslmode=require

# Separate disposable database for automated tests and verification commands.
TEST_DATABASE_URL=postgres://USERNAME:PASSWORD@HOST:5432/workflow_app_test?sslmode=require

# Optional OpenAI provider configuration for the Milestone 6 live AI path.
# Leave these unset for the default provider-independent build and test flow.
OPENAI_API_KEY=
OPENAI_MODEL=

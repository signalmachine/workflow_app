</section>

<div class="three-up">
  {{template "web_summary_card" (dict "label" "Stock balances" "value" (len .Inventory.Stock) "body" "Current filtered stock rows" "action_href" "/app/review/inventory#stock-balances" "action_label" "Open stock" )}}
  {{template "web_summary_card" (dict "label" "Movement history" "value" (len .Inventory.Movements) "body" "Current filtered movements" "action_href" "/app/review/inventory#movement-history" "action_label" "Open movements" )}}
  {{template "web_summary_card" (dict "label" "Reconciliation" "value" (len .Inventory.Reconciliation) "body" "Current filtered handoff rows" "action_href" "/app/review/inventory#reconciliation" "action_label" "Open reconciliation" )}}
</div>

<section class="table-card" id="stock-balances">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inventory stock</div>
      <h2>Stock balances</h2>
    </div>
  </div>
  {{if .Inventory.Stock}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Item</th>
          <th>Location</th>
          <th>On hand</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Inventory.Stock}}
        <tr>
          <td><a href="{{inventoryItemHref .ItemID}}">{{.ItemSKU}}</a><div class="meta">{{.ItemName}}</div></td>
          <td><a href="{{inventoryLocationHref .LocationID}}">{{.LocationCode}}</a><div class="meta">{{.LocationName}}</div></td>
          <td>{{.OnHandMilli}}</td>
          <td class="inline-links">
            <a href="{{inventoryReviewHref "" .ItemID .LocationID "" "" false false "movement-history"}}">Movement history</a>
            <a href="{{inventoryReviewHref "" .ItemID "" "" "" false false "reconciliation"}}">Reconciliation</a>
            <a href="{{inventoryLocationHref .LocationID}}">Open location</a>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No stock balances match the current filters." "body" "Item and location balances will appear here once inventory truth exists for this operator." )}}
  {{end}}
</section>

<section class="table-card" id="movement-history">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inventory movements</div>
      <h2>Movement history</h2>
    </div>
  </div>
  {{if .Inventory.Movements}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Movement</th>
          <th>Item</th>
          <th>Quantity</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Inventory.Movements}}
        <tr>
          <td><a href="{{inventoryMovementHref .MovementID}}">Movement #{{.MovementNumber}}</a><div class="meta">{{.MovementType}} / {{.MovementPurpose}}</div></td>
          <td><a href="{{inventoryItemHref .ItemID}}">{{.ItemSKU}}</a><div class="meta">{{.ItemName}}</div></td>
          <td>{{.QuantityMilli}}</td>
          <td class="inline-links">
            {{if .DocumentID.Valid}}<a href="{{documentReviewHref .DocumentID.String}}">Document</a>{{end}}
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            {{if .RecommendationID.Valid}}<a href="{{proposalDetailHref .RecommendationID.String}}">Proposal</a>{{end}}
            {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">{{if .ApprovalQueueCode.Valid}}{{.ApprovalQueueCode.String}}{{else}}Approval{{end}}</a>{{end}}
            <a href="/app/review/audit?entity_type=inventory_ops.movement&amp;entity_id={{.MovementID}}">Audit trail</a>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No movements match the current filters." "body" "Movement history will appear here once inventory transactions land in the shared backend." )}}
  {{end}}
</section>

<section class="table-card" id="reconciliation">
  <div class="section-head">
    <div>
      <div class="eyebrow">Inventory reconciliation</div>
      <h2>Execution and accounting handoff review</h2>
    </div>
  </div>
  {{if .Inventory.Reconciliation}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Document line</th>
          <th>Movement</th>
          <th>Handoffs</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Inventory.Reconciliation}}
        <tr>
          <td><a href="{{documentReviewHref .DocumentID}}">{{.DocumentTitle}}</a><div class="meta">line {{.LineNumber}}</div></td>
          <td><a href="{{inventoryMovementHref .MovementID}}">Movement #{{.MovementNumber}}</a></td>
          <td>{{if .ExecutionLinkStatus.Valid}}{{.ExecutionLinkStatus.String}}{{else}}-{{end}} / {{if .AccountingHandoffStatus.Valid}}{{.AccountingHandoffStatus.String}}{{else}}-{{end}}</td>
          <td class="inline-links">
            {{if .WorkOrderID.Valid}}<a href="/app/review/work-orders/{{.WorkOrderID.String}}">{{.WorkOrderCode.String}}</a>{{end}}
            {{if .JournalEntryID.Valid}}<a href="{{accountingEntryHref .JournalEntryID.String}}">Entry #{{.JournalEntryNumber.Int64}}</a>{{end}}
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            <a href="/app/review/audit?entity_type=inventory_ops.movement&amp;entity_id={{.MovementID}}">Audit trail</a>
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No reconciliation rows match the current filters." "body" "Execution and accounting handoff review will appear here once inventory-backed documents are in play." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_work_orders"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Work-order review"
  "body" "Keep execution status, upstream request continuity, and downstream accounting visibility in one review family before the detail rebuild."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Browse exact work orders or narrow one document seam</h2>
    </div>
  </div>
  <form method="get" action="/app/review/work-orders" class="filter-grid">
    <label>
      Work-order ID
      <input type="text" name="work_order_id" value="{{.WorkOrders.WorkOrderID}}" placeholder="work-order-123">
    </label>
    <label>
      Status
      <input type="text" name="status" value="{{.WorkOrders.Status}}" placeholder="open, in_progress, closed">
    </label>
    <label>
      Document ID
      <input type="text" name="document_id" value="{{.WorkOrders.DocumentID}}" placeholder="doc-123">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/work-orders" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Work orders</div>
      <h2>Execution review stays tied to source workflow context</h2>
    </div>
  </div>
  {{if .WorkOrders.WorkOrders}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Work order</th>
          <th>Status</th>
          <th>Execution</th>
          <th>Updated</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .WorkOrders.WorkOrders}}
        <tr>
          <td><a href="/app/review/work-orders/{{.WorkOrderID}}">{{.WorkOrderCode}}</a><div class="meta">{{.Title}}</div></td>
          <td><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></td>
          <td>{{.OpenTaskCount}} open / {{.CompletedTaskCount}} completed<div class="meta">{{.LaborEntryCount}} labor / {{.MaterialUsageCount}} material</div></td>
          <td>{{formatTime .UpdatedAt}}</td>
          <td class="inline-links">
            <a href="{{documentReviewHref .DocumentID}}">Source document</a>
            {{if .RequestReference.Valid}}<a href="{{inboundRequestHref .RequestReference.String}}">{{.RequestReference.String}}</a>{{end}}
            {{if .RecommendationID.Valid}}<a href="{{proposalDetailHref .RecommendationID.String}}">{{if .RecommendationStatus.Valid}}{{.RecommendationStatus.String}}{{else}}Proposal{{end}}</a>{{end}}
            {{if .ApprovalID.Valid}}<a href="{{approvalReviewHref .ApprovalID.String}}">{{if .ApprovalStatus.Valid}}{{.ApprovalStatus.String}}{{else}}Approval{{end}}</a>{{end}}
            {{if .RunID.Valid}}<a href="{{inboundSectionHref (print "run:" .RunID.String) (runSectionID .RunID.String)}}">AI run</a>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No work orders match the current filters." "body" "Execution review rows will appear here when source documents create work-order truth." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "web_audit"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Review workbench"
  "title" "Audit lookup"
  "body" "Browse durable audit events by exact event ID or entity continuity without dropping into the detail routes first."
)}}

<section class="panel section-stack">
  <div class="section-head">
    <div>
      <div class="eyebrow">Filters</div>
      <h2>Use one seam for exact event or entity-scoped lookup</h2>
    </div>
  </div>
  <form method="get" action="/app/review/audit" class="filter-grid">
    <label>
      Event ID
      <input type="text" name="event_id" value="{{.Audit.EventID}}" placeholder="audit-123">
    </label>
    <label>
      Entity type
      <input type="text" name="entity_type" value="{{.Audit.EntityType}}" placeholder="documents.document">
    </label>
    <label>
      Entity ID
      <input type="text" name="entity_id" value="{{.Audit.EntityID}}" placeholder="doc-123">
    </label>
    <div class="filter-actions">
      <button type="submit">Apply filters</button>
      <a href="/app/review/audit" class="pill-link">Clear filters</a>
    </div>
  </form>
</section>

<section class="table-card">
  <div class="section-head">
    <div>
      <div class="eyebrow">Audit events</div>
      <h2>Exact events remain the durable reconstruction seam</h2>
    </div>
  </div>
  {{if .Audit.Events}}
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Event</th>
          <th>Type</th>
          <th>Entity</th>
          <th>Occurred</th>
          <th>Continuity</th>
        </tr>
      </thead>
      <tbody>
        {{range .Audit.Events}}
        <tr>
          <td><a href="{{auditEventHref .ID}}">{{.ID}}</a></td>
          <td>{{.EventType}}</td>
          <td>{{auditEntityLabel .EntityType}}</td>
          <td>{{formatTime .OccurredAt}}</td>
          <td class="inline-links">
            <a href="{{auditEntityHref .EntityType .EntityID}}">Entity trail</a>
            {{if .ActorUserID.Valid}}<span class="meta">{{.ActorUserID.String}}</span>{{end}}
          </td>
        </tr>
        {{end}}
      </tbody>
    </table>
  </div>
  {{else}}
  {{template "web_empty_state" (dict "title" "No audit events match the current filters." "body" "Audit rows will appear here once durable workflow actions exist for the selected entity or event." )}}
  {{end}}
</section>

{{template "web_shell_end" .}}
{{end}}

{{define "slice1_styles"}}
:root {
  --bg: #f3f6fb;
  --surface: #ffffff;
  --surface-muted: #e6edf6;
  --surface-strong: #10263f;
  --ink: #112033;
  --ink-soft: #5d6b7c;
  --line: #cfdae6;
  --line-strong: #a8b8ca;
  --accent: #0d5bd7;
  --accent-strong: #0a3f97;
  --accent-soft: #dbe8ff;
  --good: #157347;
  --bad: #b02a37;
  --neutral: #627487;
  --shadow: 0 18px 40px rgba(17, 32, 51, 0.08);
  --radius-xl: 24px;
  --radius-lg: 18px;
  --radius-md: 12px;
  --radius-sm: 999px;
  --max-width: 1280px;
  --font-sans: "IBM Plex Sans", "Segoe UI", sans-serif;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: linear-gradient(180deg, #f7f9fc 0%, #edf3fb 100%); color: var(--ink); font-family: var(--font-sans); }
body { min-height: 100vh; }
a { color: var(--accent-strong); text-decoration: none; }
a:hover { text-decoration: underline; }

.pill-link,
.button-link,
button,
input[type="submit"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  background: var(--accent);
  color: #fff;
  font: inherit;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
}

.pill-link.secondary,
.button-link.secondary,
button.secondary,
input[type="submit"].secondary {
  background: var(--surface);
  color: var(--accent-strong);
  border-color: var(--line);
}

.button-row,
.action-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.flash-stack {
  display: grid;
  gap: 12px;
}

.flash {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  border: 1px solid var(--line);
  background: var(--surface);
  box-shadow: var(--shadow);
}

.flash.notice {
  border-color: #b7d0ff;
  background: #eef5ff;
}

.flash.error {
  border-color: #efb4bc;
  background: #fff1f3;
}

.public-shell {
  width: min(1120px, calc(100vw - 32px));
  margin: 0 auto;
  padding: 32px 0 48px;
}

.shell-grid {
  width: min(var(--max-width), calc(100vw - 32px));
  margin: 0 auto;
  padding: 24px 0 40px;
  display: grid;
  grid-template-columns: 280px minmax(0, 1fr);
  gap: 24px;
}

.shell-sidebar {
  background: linear-gradient(180deg, #112842 0%, #183758 100%);
  color: #eff6ff;
  border-radius: 28px;
  padding: 24px 20px;
  box-shadow: var(--shadow);
  position: sticky;
  top: 24px;
  height: fit-content;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  border-radius: var(--radius-sm);
  background: rgba(255, 255, 255, 0.12);
  color: #d7e7ff;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.brand-block h1,
.brand-block h2,
.brand-block p { margin: 0; }

.brand-block {
  display: grid;
  gap: 12px;
  margin-bottom: 24px;
}

.brand-block h1 {
  font-size: 1.6rem;
  line-height: 1.1;
}

.brand-block p,
.nav-group-copy,
.session-meta,
.panel-subtitle,
.meta,
.eyebrow,
.section-copy {
  color: var(--ink-soft);
}

.shell-sidebar .nav-group-copy,
.shell-sidebar .session-meta {
  color: #bdd2ec;
}

.nav-stack {
  display: grid;
  gap: 18px;
}

.nav-group {
  display: grid;
  gap: 8px;
}

.nav-group-label {
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #98b6d6;
}

.nav-link {
  display: block;
  padding: 11px 14px;
  border-radius: 14px;
  color: #dce9f9;
  text-decoration: none;
  background: rgba(255, 255, 255, 0.03);
}

.nav-link:hover,
.nav-link.is-active {
  background: rgba(255, 255, 255, 0.12);
  color: #ffffff;
  text-decoration: none;
}

.shell-main {
  display: grid;
  gap: 20px;
}

.topbar,
.panel,
.table-card,
.summary-card,
.detail-block,
.feed-item,
.hero-card,
.result-card {
  background: var(--surface);
  border: 1px solid rgba(168, 184, 202, 0.4);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
}

.topbar {
  padding: 18px 22px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

.page-stack {
  display: grid;
  gap: 20px;
}

.page-header,
.hero-card,
.panel,
.result-card,
.feed-item,
.table-card {
  padding: 24px;
}

.page-header {
  display: grid;
  gap: 14px;
}

.eyebrow {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.page-header h1,
.hero-card h2,
.panel h2,
.panel h3,
.table-card h2,
.table-card h3,
.summary-card h3,
.result-card h2 {
  margin: 0;
}

.page-header p,
.hero-card p,
.panel p,
.table-card p,
.result-card p {
  margin: 0;
  line-height: 1.6;
}

.hero-card {
  display: grid;
  gap: 18px;
  background:
    radial-gradient(circle at top right, rgba(13, 91, 215, 0.16), transparent 36%),
    linear-gradient(135deg, #ffffff 0%, #eef5ff 100%);
}

.hero-grid,
.two-up,
.three-up,
.status-grid {
  display: grid;
  gap: 16px;
}

.hero-grid {
  grid-template-columns: minmax(0, 1.6fr) minmax(280px, 1fr);
}

.two-up {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-up {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.status-grid {
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
}

.summary-card,
.detail-block {
  padding: 18px;
}

.summary-card .count {
  font-size: 2rem;
  font-weight: 700;
}

.summary-card .meta,
.detail-block .meta {
  margin-top: 8px;
}

.result-card {
  border-color: #bfd4ff;
  background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%);
}

.table-card {
  display: grid;
  gap: 16px;
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
}

table {
  width: 100%;
  min-width: 640px;
  border-collapse: collapse;
}

th,
td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: top;
}

th {
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--ink-soft);
  background: #f7f9fc;
}

tr:last-child td { border-bottom: 0; }

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: var(--radius-sm);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background: #edf3fb;
  color: var(--neutral);
}

.status-good { background: #e8f5ee; color: var(--good); }
.status-bad { background: #fff0f1; color: var(--bad); }
.status-neutral { background: #edf3fb; color: var(--neutral); }

.field-grid {
  display: grid;
  gap: 14px;
}

.field-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

label {
  display: grid;
  gap: 8px;
  font-weight: 600;
}

input[type="text"],
input[type="email"],
input[type="password"],
textarea,
input[type="file"] {
  width: 100%;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: #fff;
  color: var(--ink);
  font: inherit;
}

textarea { min-height: 180px; resize: vertical; }

.feed-list,
.card-stack,
.detail-grid {
  display: grid;
  gap: 16px;
}

.detail-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.feed-item {
  display: grid;
  gap: 12px;
}

.feed-head {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: space-between;
  align-items: baseline;
}

.empty-state {
  padding: 18px;
  border-radius: var(--radius-lg);
  border: 1px dashed var(--line-strong);
  background: #f8fbff;
}

.empty-state h3 {
  margin: 0 0 8px;
}

.login-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.9fr);
  gap: 24px;
  align-items: start;
}

.login-panel {
  padding: 24px;
}

.login-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
}

@media (max-width: 1080px) {
  .shell-grid,
  .hero-grid,
  .three-up,
  .two-up,
  .login-grid,
  .field-grid.two {
    grid-template-columns: 1fr;
  }

  .shell-sidebar {
    position: static;
  }
}

@media (max-width: 720px) {
  .public-shell,
  .shell-grid {
    width: min(100vw - 20px, var(--max-width));
  }

  .page-header,
  .hero-card,
  .panel,
  .table-card,
  .result-card,
  .feed-item,
  .summary-card,
  .detail-block {
    padding: 18px;
  }

  th,
  td {
    padding: 12px;
  }
}
{{end}}

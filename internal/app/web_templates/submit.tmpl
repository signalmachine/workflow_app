{{define "slice1_submit"}}
{{template "slice1_shell_start" .}}

{{template "slice1_page_header" (dict
  "eyebrow" "Dedicated intake"
  "title" "Submit one inbound request without diluting the dashboard."
  "body" "Use the dedicated intake page for browser-originated requests, keep continuity with exact REQ references, and preserve a clean path back into the dashboard or review."
)}}

{{if .InboundSubmit.RequestReference}}
<section class="result-card">
  <div class="eyebrow">Latest submission</div>
  <h2>{{.InboundSubmit.RequestReference}}</h2>
  <p>Inbound request status: <span class="status-pill {{statusClass .InboundSubmit.RequestStatus}}">{{.InboundSubmit.RequestStatus}}</span></p>
  <div class="button-row">
    <a href="/app/inbound-requests/{{.InboundSubmit.RequestReference}}" class="pill-link">Open exact request detail</a>
    <a href="/app/review/inbound-requests?request_reference={{.InboundSubmit.RequestReference}}" class="pill-link secondary">Open request review</a>
    <a href="/app" class="pill-link secondary">Return to dashboard</a>
  </div>
</section>
{{end}}

<section class="panel">
  <h2>Dedicated intake</h2>
  <p class="panel-subtitle">This route stays focused on inbound-request creation. Drafting, queueing, and attachment capture all continue through the same persisted intake model.</p>
  <form method="post" action="/app/inbound-requests" enctype="multipart/form-data" class="field-grid" style="margin-top: 18px;">
    <input type="hidden" name="return_to" value="/app/submit-inbound-request">
    <input type="hidden" name="channel" value="browser">
    <div class="field-grid two">
      <label>
        Submitter label
        <input type="text" name="submitter_label" placeholder="front desk, warehouse, field lead">
      </label>
      <label>
        Attachments
        <input type="file" name="attachments" multiple>
      </label>
    </div>
    <label>
      Request message
      <textarea name="message_text" placeholder="Describe the inbound request, the workflow context, and any review constraints that matter." required></textarea>
    </label>
    <div class="action-group">
      <button type="submit">Queue inbound request</button>
      <button type="submit" name="intent" value="save_draft" class="secondary">Save draft</button>
      <a href="/app/review/inbound-requests" class="pill-link secondary">Open inbound review</a>
    </div>
  </form>
</section>

{{template "slice1_shell_end" .}}
{{end}}

{{define "web_agent_chat"}}
{{template "web_shell_start" .}}

{{template "web_page_header" (dict
  "eyebrow" "Agent chat"
  "title" "Coordinator chat"
  "body" "Guidance-oriented conversations use the same persisted inbound-request foundation, but stay distinct from ordinary browser submissions so operators can review them cleanly."
)}}

{{if .AgentChat.RequestReference}}
<section class="result-card">
  <div class="eyebrow">Latest coordinator request</div>
  <h2>{{.AgentChat.RequestReference}}</h2>
  <p>Inbound request status: <span class="status-pill {{statusClass .AgentChat.RequestStatus}}">{{.AgentChat.RequestStatus}}</span></p>
  <div class="button-row">
    <a href="/app/inbound-requests/{{.AgentChat.RequestReference}}" class="pill-link">Open exact request detail</a>
    <a href="/app/review/proposals?request_reference={{.AgentChat.RequestReference}}" class="pill-link secondary">Open proposal continuity</a>
    <a href="/app/operations-feed" class="pill-link secondary">Open operations feed</a>
  </div>
</section>
{{end}}

<section class="panel">
  <h2>Start a coordinator conversation</h2>
  <p class="panel-subtitle">This surface is for guidance-oriented messages that should still enter the persisted queue. It intentionally remains separate from the main intake page.</p>
  <form method="post" action="/app/inbound-requests" enctype="multipart/form-data" class="field-grid" style="margin-top: 18px;">
    <input type="hidden" name="return_to" value="/app/agent-chat">
    <input type="hidden" name="channel" value="agent_chat">
    <div class="field-grid two">
      <label>
        Submitter label
        <input type="text" name="submitter_label" placeholder="dispatch desk, supervisor, operator">
      </label>
      <label>
        Attachments
        <input type="file" name="attachments" multiple>
      </label>
    </div>
    <label>
      Guidance request
      <textarea name="message_text" placeholder="Describe the situation, the decision you want help with, and the workflow context the coordinator should preserve." required></textarea>
    </label>
    <div class="action-group">
      <button type="submit">Queue coordinator request</button>
      <button type="submit" name="intent" value="save_draft" class="secondary">Save draft</button>
      <a href="/app/review/inbound-requests" class="pill-link secondary">Open full inbound review</a>
    </div>
  </form>
</section>

<div class="two-up">
  <section class="table-card">
    <div>
      <div class="eyebrow">Recent agent-chat requests</div>
      <h2>Keep only the coordinator channel here</h2>
    </div>
    {{if .AgentChat.RecentRequests}}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Request</th>
            <th>Status</th>
            <th>Messages</th>
            <th>Next step</th>
          </tr>
        </thead>
        <tbody>
          {{range .AgentChat.RecentRequests}}
          <tr>
            <td><a href="{{inboundRequestHref .RequestReference}}">{{.RequestReference}}</a></td>
            <td><span class="status-pill {{statusClass .Status}}">{{.Status}}</span></td>
            <td>{{.MessageCount}} messages / {{.AttachmentCount}} attachments</td>
            <td><a href="{{inboundRequestHref .RequestReference}}">{{dashboardRequestAction .Status}}</a></td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{else}}
    {{template "web_empty_state" (dict "title" "No recent agent-chat requests yet." "body" "Once coordinator conversations land through the dedicated channel, they will stay isolated here from browser-originated intake." )}}
    {{end}}
  </section>

  <section class="table-card">
    <div>
      <div class="eyebrow">Recent agent-chat proposals</div>
      <h2>Proposal continuity from coordinator conversations</h2>
    </div>
    {{if .AgentChat.RecentProposals}}
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Request</th>
            <th>Proposal</th>
            <th>Status</th>
            <th>Summary</th>
          </tr>
        </thead>
        <tbody>
          {{range .AgentChat.RecentProposals}}
          <tr>
            <td><a href="{{inboundRequestHref .RequestReference}}">{{.RequestReference}}</a></td>
            <td><a href="{{proposalDetailHref .RecommendationID}}">{{.RecommendationID}}</a></td>
            <td><span class="status-pill {{statusClass .RecommendationStatus}}">{{.RecommendationStatus}}</span></td>
            <td>{{.Summary}}</td>
          </tr>
          {{end}}
        </tbody>
      </table>
    </div>
    {{else}}
    {{template "web_empty_state" (dict "title" "No recent proposals from agent-chat requests yet." "body" "Coordinator-generated proposal continuity will appear here once a queued chat request reaches a processed recommendation." )}}
    {{end}}
  </section>
</div>

{{template "web_shell_end" .}}
{{end}}

OPENAI_API_KEY=your-openai-api-key
DATABASE_URL=postgres://app:password@localhost:5432/appdb?sslmode=disable
TEST_DATABASE_URL=postgres://app:password@localhost:5432/appdb_test?sslmode=disable
JWT_SECRET=replace-with-a-long-random-secret
SERVER_PORT=8080
ALLOWED_ORIGINS=http://localhost:8080
COMPANY_CODE=1000
# Use a dedicated upload directory. If omitted, the server defaults to:
# <system temp dir>/accounting-agent-uploads
UPLOAD_DIR=/tmp/accounting-agent-uploads

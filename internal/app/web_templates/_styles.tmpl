{{define "web_styles"}}
:root {
  --bg: #f4f2e8;
  --surface: #fbfaf4;
  --surface-muted: #eef3df;
  --surface-strong: #264235;
  --ink: #171c16;
  --ink-soft: #5f665c;
  --line: #d5d9c8;
  --line-strong: #b9c0ad;
  --accent: #245f46;
  --accent-strong: #183c2c;
  --accent-soft: #ddece3;
  --good: #157347;
  --bad: #b02a37;
  --neutral: #627487;
  --shadow: 0 18px 40px rgba(17, 32, 51, 0.08);
  --radius-xl: 24px;
  --radius-lg: 18px;
  --radius-md: 12px;
  --radius-sm: 999px;
  --max-width: 1280px;
  --font-sans: "IBM Plex Sans", "Segoe UI", sans-serif;
}

* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; background: linear-gradient(180deg, #f7f4e8 0%, #eef3df 52%, #f5f7ee 100%); color: var(--ink); font-family: var(--font-sans); }
body { min-height: 100vh; }
a { color: var(--accent-strong); text-decoration: none; }
a:hover { text-decoration: underline; }

.pill-link,
.button-link,
button,
input[type="submit"] {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  background: var(--accent);
  color: #fff;
  font: inherit;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
}

.pill-link.secondary,
.button-link.secondary,
button.secondary,
input[type="submit"].secondary {
  background: var(--surface);
  color: var(--accent-strong);
  border-color: var(--line);
}

.button-row,
.action-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.flash-stack {
  display: grid;
  gap: 12px;
}

.flash {
  padding: 14px 16px;
  border-radius: var(--radius-md);
  border: 1px solid var(--line);
  background: var(--surface);
  box-shadow: var(--shadow);
}

.flash.notice {
  border-color: #b7d0ff;
  background: #eef5ff;
}

.flash.error {
  border-color: #efb4bc;
  background: #fff1f3;
}

.public-shell {
  width: min(1120px, calc(100vw - 32px));
  margin: 0 auto;
  padding: 32px 0 48px;
}

.shell-frame {
  width: min(var(--max-width), calc(100vw - 32px));
  margin: 0 auto;
  padding: 24px 0 40px;
  display: grid;
  gap: 20px;
}

.shell-header {
  display: grid;
  gap: 16px;
}

.brand-mark {
  display: inline-flex;
  align-items: center;
  padding: 6px 12px;
  border-radius: var(--radius-sm);
  background: #e6edd2;
  color: #355441;
  font-size: 0.82rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.brand-block h1,
.brand-block h2,
.brand-block p { margin: 0; }

.brand-block {
  display: grid;
  gap: 12px;
}

.brand-block h1 {
  font-size: 1.6rem;
  line-height: 1.1;
}

.brand-block p,
.session-meta,
.panel-subtitle,
.meta,
.eyebrow,
.section-copy {
  color: var(--ink-soft);
}

.shell-header-row {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.9fr);
  gap: 18px;
  align-items: start;
}

.session-card,
.shell-nav,
.panel,
.table-card,
.summary-card,
.detail-block,
.feed-item,
.hero-card,
.result-card {
  background: var(--surface);
  border: 1px solid rgba(185, 192, 173, 0.7);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow);
}

.session-card,
.shell-nav {
  padding: 18px 22px;
}

.session-card {
  display: grid;
  gap: 10px;
  background: linear-gradient(135deg, #fbfaf4 0%, #f0f4e5 100%);
}

.session-title {
  line-height: 1.5;
}

.shell-nav {
  display: grid;
  gap: 14px;
}

.nav-band {
  display: grid;
  gap: 8px;
}

.nav-band-label {
  font-size: 0.76rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #637355;
}

.nav-bubbles {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 12px;
}

.nav-link {
  display: inline-flex;
  align-items: center;
  min-height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  color: var(--accent-strong);
  text-decoration: none;
  background: #f5f4eb;
  border: 1px solid var(--line);
  font-weight: 600;
}

.nav-link:hover,
.nav-link.is-active {
  background: var(--accent-soft);
  border-color: #8fb49f;
  color: var(--accent-strong);
  text-decoration: none;
}

.utility-menu summary {
  list-style: none;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 40px;
  padding: 0 16px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--line);
  background: #f5f4eb;
  font-weight: 600;
}

.utility-menu summary::-webkit-details-marker {
  display: none;
}

.utility-menu[open] summary {
  background: var(--accent-soft);
  border-color: #8fb49f;
}

.utility-menu-panel {
  display: grid;
  gap: 12px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--line);
}

.shell-main {
  display: grid;
  gap: 20px;
}

.page-stack {
  display: grid;
  gap: 20px;
}

.page-header,
.hero-card,
.panel,
.result-card,
.feed-item,
.table-card {
  padding: 24px;
}

.page-header {
  display: grid;
  gap: 14px;
}

.eyebrow {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.page-header h1,
.hero-card h2,
.panel h2,
.panel h3,
.table-card h2,
.table-card h3,
.summary-card h3,
.result-card h2 {
  margin: 0;
}

.page-header p,
.hero-card p,
.panel p,
.table-card p,
.result-card p {
  margin: 0;
  line-height: 1.6;
}

.hero-card {
  display: grid;
  gap: 18px;
  background:
    radial-gradient(circle at top right, rgba(36, 95, 70, 0.14), transparent 36%),
    linear-gradient(135deg, #fbfaf4 0%, #eef3df 100%);
}

.hero-grid,
.two-up,
.three-up,
.status-grid {
  display: grid;
  gap: 16px;
}

.hero-grid {
  grid-template-columns: minmax(0, 1.6fr) minmax(280px, 1fr);
}

.two-up {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.three-up {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.status-grid {
  grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
}

.summary-card,
.detail-block {
  padding: 18px;
}

.summary-card .count {
  font-size: 2rem;
  font-weight: 700;
}

.summary-card .meta,
.detail-block .meta {
  margin-top: 8px;
}

.detail-card {
  padding: 18px;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid var(--line);
}

.result-card {
  border-color: #bfd2c2;
  background: linear-gradient(135deg, #fbfaf4 0%, #edf4e9 100%);
}

.table-card {
  display: grid;
  gap: 16px;
}

.table-wrap {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
}

table {
  width: 100%;
  border-collapse: collapse;
}

.table-wrap > table {
  min-width: 640px;
}

th,
td {
  padding: 14px 16px;
  border-bottom: 1px solid var(--line);
  text-align: left;
  vertical-align: top;
}

th {
  font-size: 0.82rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--ink-soft);
  background: #f6f5ee;
}

tr:last-child td { border-bottom: 0; }

.status-pill {
  display: inline-flex;
  align-items: center;
  padding: 5px 10px;
  border-radius: var(--radius-sm);
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  background: #edf3fb;
  color: var(--neutral);
}

.status-good { background: #e8f5ee; color: var(--good); }
.status-bad { background: #fff0f1; color: var(--bad); }
.status-neutral { background: #edf3fb; color: var(--neutral); }

.field-grid {
  display: grid;
  gap: 14px;
}

.filter-grid {
  display: grid;
  gap: 14px;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  align-items: end;
}

.filter-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: center;
}

.field-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

label {
  display: grid;
  gap: 8px;
  font-weight: 600;
}

input[type="text"],
input[type="email"],
input[type="password"],
input[type="date"],
textarea,
select,
input[type="file"] {
  width: 100%;
  padding: 12px 14px;
  border-radius: 14px;
  border: 1px solid var(--line);
  background: #fff;
  color: var(--ink);
  font: inherit;
}

textarea { min-height: 180px; resize: vertical; }

.feed-list,
.card-stack,
.detail-grid,
.review-link-list {
  display: grid;
  gap: 16px;
}

.page-actions,
.compact-form {
  display: grid;
  gap: 12px;
}

.detail-grid {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

.feed-item {
  display: grid;
  gap: 12px;
}

.feed-head {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: space-between;
  align-items: baseline;
}

.empty-state {
  padding: 18px;
  border-radius: var(--radius-lg);
  border: 1px dashed var(--line-strong);
  background: #f7f7ef;
}

.empty-state h3 {
  margin: 0 0 8px;
}

.section-stack {
  display: grid;
  gap: 18px;
}

.section-head {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 12px;
  align-items: start;
}

.section-head h2,
.section-head p {
  margin: 0;
}

pre {
  margin: 0;
  padding: 16px;
  border-radius: var(--radius-lg);
  background: #f5f6ee;
  border: 1px solid var(--line);
  overflow-x: auto;
  font-family: "IBM Plex Mono", "SFMono-Regular", monospace;
  font-size: 0.9rem;
  line-height: 1.55;
}

details {
  display: grid;
  gap: 12px;
}

summary {
  cursor: pointer;
  font-weight: 600;
}

.inline-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px 14px;
}

.compact-copy {
  font-size: 0.95rem;
}

.login-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.9fr);
  gap: 24px;
  align-items: start;
}

.login-panel {
  padding: 24px;
}

.login-shell {
  min-height: 100vh;
  display: flex;
  align-items: center;
}

@media (max-width: 1080px) {
  .shell-header-row,
  .hero-grid,
  .three-up,
  .two-up,
  .login-grid,
  .field-grid.two {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 720px) {
  .public-shell,
  .shell-frame {
    width: min(100vw - 20px, var(--max-width));
  }

  .session-card,
  .shell-nav,
  .page-header,
  .hero-card,
  .panel,
  .table-card,
  .result-card,
  .feed-item,
  .summary-card,
  .detail-block {
    padding: 18px;
  }

  th,
  td {
    padding: 12px;
  }

  .nav-bubbles {
    gap: 8px;
  }

  .nav-link,
  .utility-menu summary {
    width: 100%;
    justify-content: center;
  }
}
{{end}}

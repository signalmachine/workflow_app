{{define "slice1_login"}}
{{template "slice1_public_start" .}}
<div class="login-grid">
  <section class="hero-card">
    <div class="eyebrow">Browser session</div>
    <h2>Sign in to the rebuilt operator shell.</h2>
    <p>This sign-in surface only issues the browser-session path.</p>
    <div class="detail-grid">
      {{template "slice1_detail_block" (dict "label" "Workflow stance" "value" "Persist first, review first" "body" "Requests land durably before AI processing or downstream approvals.")}}
      {{template "slice1_detail_block" (dict "label" "Shared seam" "value" "/app plus /api" "body" "The browser shell stays on the same backend truth used by the API and later clients.")}}
      {{template "slice1_detail_block" (dict "label" "Current slice" "value" "Milestone 10 Slice 1" "body" "Architecture, shell, and operator-entry surfaces are the active v2 implementation boundary.")}}
    </div>
  </section>

  <section class="panel login-panel">
    <div class="eyebrow">Sign in</div>
    <h2>Start browser session</h2>
    <p class="panel-subtitle">This shell stays thin on purpose: authenticate, continue into intake, then use the review workbench only when you need broader context.</p>
    <form method="post" action="/app/login" class="field-grid" style="margin-top: 18px;">
      <label>
        Organization slug
        <input type="text" name="org_slug" autocomplete="organization" required>
      </label>
      <label>
        Email
        <input type="email" name="email" autocomplete="email" required>
      </label>
      <label>
        Password
        <input type="password" name="password" autocomplete="current-password" required>
      </label>
      <label>
        Device label
        <input type="text" name="device_label" value="browser">
      </label>
      <div class="action-group">
        <button type="submit">Sign in</button>
      </div>
    </form>
  </section>
</div>
{{template "slice1_public_end" .}}
{{end}}
